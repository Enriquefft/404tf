---
import { CorporateFormStandalone } from "@/components/corporate-form-standalone";
import TrustSignal from "@/components/trust-signal.astro";
import seedData from "@/data/seed.json";
import { getTranslations } from "@/i18n/translations";
import BaseLayout from "@/layouts/BaseLayout.astro";

const locale = "es" as const;
const t = getTranslations(locale);
const c = t.corporate;

// Minimal startup data for context matching via ?startup= query param
const startups = seedData.map((s) => ({
	slug: s.slug,
	name: s.name,
	vertical: s.verticals?.[0] ?? "other",
}));
---

<BaseLayout
	title={`${c.contactTitle} — ${t.meta.siteTitle}`}
	description={c.contactSubtitle}
	locale={locale}
>
	<section class="ds-section mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8">
		{/* Hero */}
		<div class="mx-auto mb-12 max-w-2xl text-center">
			<h1
				class="text-4xl font-bold tracking-tight sm:text-5xl"
				style="font-family: var(--font-display); color: var(--foreground);"
			>
				{c.contactTitle}
			</h1>
			<p
				class="mt-4 text-lg"
				style="font-family: var(--font-body); color: var(--muted-foreground);"
			>
				{c.contactSubtitle}
			</p>
		</div>

		{/* Standalone form */}
		<CorporateFormStandalone
			client:load
			locale={locale}
			startups={startups}
		/>

		{/* Trust signals */}
		<div class="mx-auto mt-8 flex max-w-lg flex-col items-center gap-3 sm:flex-row sm:justify-center sm:gap-6">
			<TrustSignal label={c.trustStep1} />
			<TrustSignal label={c.trustStep2} />
		</div>
	</section>
</BaseLayout>
