---
export const prerender = false;

import { FoundingChart } from "@/components/charts/founding-chart";
import { GeoChart } from "@/components/charts/geo-chart";
import { VerticalChart } from "@/components/charts/vertical-chart";
import CorporateCta from "@/components/corporate-cta.astro";
import { PdfDownloadForm } from "@/components/pdf-download-form";
import Card from "@/components/ui/card.astro";
import SectionLabel from "@/components/ui/section-label.astro";
import StatBlock from "@/components/ui/stat-block.astro";
import { getTranslations } from "@/i18n/translations";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { CACHE_TAGS, joinCacheTags } from "@/lib/cache-tags";
import { fillTemplate, formatCurrency, getInsightsData } from "@/lib/db-queries";

const locale = "es" as const;
const t = getTranslations(locale);

const {
	countryCount,
	countryDistribution,
	foundingInsight,
	foundingTimeline,
	fundingInsight,
	fundingStats,
	geoInsight,
	maturityDistribution,
	maturityInsight,
	totalStartups,
	verticalDistribution,
	verticalInsight,
} = await getInsightsData();

Astro.response.headers.set("Cache-Control", "public, s-maxage=3600, stale-while-revalidate=86400");
Astro.response.headers.set(
	"Cache-Tag",
	joinCacheTags([CACHE_TAGS.insights, CACHE_TAGS.startupAll]),
);

const geoInsightText = fillTemplate(t.insights.geoInsight, {
	leader: geoInsight.leaderCountryEs,
	leaderCount: geoInsight.leaderCount,
	multiple: geoInsight.leaderMultiple,
	second: geoInsight.secondCountryEs ?? "",
});

const verticalInsightText = fillTemplate(t.insights.verticalInsight, {
	leader: verticalInsight.leaderLabelEs,
	count: verticalInsight.leaderCount,
	share: verticalInsight.topThreeShare,
});

const foundingInsightText = fillTemplate(t.insights.foundingInsight, {
	year: foundingInsight.peakYear,
	count: foundingInsight.peakCount,
	pct: foundingInsight.lastFiveYearShare,
});

const foundingPeakLabel = fillTemplate(t.insights.foundingPeakAnnotation, {
	year: foundingInsight.peakYear,
});

const maturityInsightText = fillTemplate(t.insights.maturityInsight, {
	earlyPct: maturityInsight.earlyStagePct,
	commercialPct: maturityInsight.commercialPct,
});

const fundingInsightText = fillTemplate(t.insights.fundingInsight, {
	total: formatCurrency(fundingStats.totalDisclosed),
	count: fundingStats.withFunding,
	share: fundingInsight.topThreeShare,
});

const execFundingCompare = fillTemplate(t.insights.execFundingCompare, {
	pct: fundingStats.withFundingPct,
});
---

<BaseLayout
	title={`${t.insights.title} — ${t.meta.siteTitle}`}
	description={t.insights.subtitle}
	locale={locale}
	ogImage={`/og/?kind=insights&locale=${locale}&metric=${encodeURIComponent(`${totalStartups}+`)}`}
>
	<!-- Header -->
	<section class="ds-section mx-auto max-w-4xl px-4 py-20 text-center sm:px-6 lg:px-8">
		<p
			class="text-xs font-semibold uppercase mb-4"
			style="font-family: var(--font-mono); color: var(--secondary); letter-spacing: 0.12em;"
		>
			{t.insights.heroKicker}
		</p>
		<p
			class="text-xs font-semibold uppercase text-muted-foreground tracking-widest mb-4"
			style="font-family: var(--font-heading);"
		>
			{t.insights.byline}
		</p>
		<h1
			class="text-4xl font-bold tracking-tight text-foreground sm:text-5xl lg:text-6xl"
			style="font-family: var(--font-display);"
		>
			{t.insights.title}
		</h1>
		<p
			class="mt-6 text-lg text-muted-foreground leading-relaxed max-w-2xl mx-auto"
			style="font-family: var(--font-body);"
		>
			{t.insights.subtitle}
		</p>
	</section>

	<!-- Executive Summary -->
	<section class="ds-section mx-auto max-w-4xl px-4 pb-20 sm:px-6 lg:px-8">
		<div class="grid grid-cols-1 gap-8 sm:grid-cols-3">
			<div class="text-center flex flex-col items-center">
				<StatBlock value={`${totalStartups}+`} label={t.insights.execStartups} size="hero" />
				<span
					class="mt-2 text-xs uppercase"
					style="font-family: var(--font-mono); color: var(--text-tertiary); letter-spacing: 0.1em;"
				>
					{t.insights.execStartupsCompare}
				</span>
			</div>
			<div class="text-center flex flex-col items-center">
				<StatBlock value={`${countryCount}`} label={t.insights.execCountries} size="hero" />
				<span
					class="mt-2 text-xs uppercase"
					style="font-family: var(--font-mono); color: var(--text-tertiary); letter-spacing: 0.1em;"
				>
					{t.insights.execCountriesCompare}
				</span>
			</div>
			<div class="text-center flex flex-col items-center">
				<StatBlock
					value={formatCurrency(fundingStats.totalDisclosed)}
					label={t.insights.execFunding}
					size="hero"
				/>
				<span
					class="mt-2 text-xs uppercase"
					style="font-family: var(--font-mono); color: var(--text-tertiary); letter-spacing: 0.1em;"
				>
					{execFundingCompare}
				</span>
			</div>
		</div>
	</section>

	<!-- Geographic Distribution -->
	<section class="ds-section mx-auto max-w-4xl px-4 pb-20 sm:px-6 lg:px-8">
		<p
			class="text-xs font-semibold uppercase mb-2"
			style="font-family: var(--font-mono); color: var(--secondary); letter-spacing: 0.12em;"
		>
			{t.insights.geoKicker}
		</p>
		<SectionLabel text={t.insights.geoLabel} />
		<h2
			class="mt-3 text-2xl font-bold text-foreground sm:text-3xl"
			style="font-family: var(--font-display);"
		>
			{t.insights.geoTitle}
		</h2>
		<div class="mt-8">
			<GeoChart
				client:visible
				data={countryDistribution}
				directoryPath="/es/directorio"
			/>
		</div>
		<div
			class="mt-8 border-l-2 pl-5 py-1"
			style="border-color: var(--secondary);"
		>
			<p
				class="text-xs font-semibold uppercase mb-2"
				style="font-family: var(--font-mono); color: var(--secondary); letter-spacing: 0.12em;"
			>
				{t.insights.insightTag}
			</p>
			<p
				class="text-lg italic text-foreground leading-relaxed"
				style="font-family: var(--font-body);"
			>
				{geoInsightText}
			</p>
			<p
				class="mt-3 text-xs uppercase"
				style="font-family: var(--font-mono); color: var(--text-tertiary); letter-spacing: 0.08em;"
			>
				{t.insights.sourceLine}
			</p>
		</div>
	</section>

	<!-- Vertical Breakdown -->
	<section class="ds-section mx-auto max-w-4xl px-4 pb-20 sm:px-6 lg:px-8">
		<p
			class="text-xs font-semibold uppercase mb-2"
			style="font-family: var(--font-mono); color: var(--secondary); letter-spacing: 0.12em;"
		>
			{t.insights.verticalKicker}
		</p>
		<div class="flex items-baseline justify-between gap-4">
			<SectionLabel text={t.insights.verticalLabel} />
			<span
				class="text-xs font-semibold uppercase"
				style="font-family: var(--font-mono); color: var(--secondary); letter-spacing: 0.12em;"
			>
				{t.insights.verticalTopThree}
			</span>
		</div>
		<h2
			class="mt-3 text-2xl font-bold text-foreground sm:text-3xl"
			style="font-family: var(--font-display);"
		>
			{t.insights.verticalTitle}
		</h2>
		<div class="mt-8">
			<VerticalChart
				client:load
				data={verticalDistribution}
				locale={locale}
				directoryPath="/es/directorio"
			/>
		</div>
		<div
			class="mt-8 border-l-2 pl-5 py-1"
			style="border-color: var(--secondary);"
		>
			<p
				class="text-xs font-semibold uppercase mb-2"
				style="font-family: var(--font-mono); color: var(--secondary); letter-spacing: 0.12em;"
			>
				{t.insights.insightTag}
			</p>
			<p
				class="text-lg italic text-foreground leading-relaxed"
				style="font-family: var(--font-body);"
			>
				{verticalInsightText}
			</p>
			<p
				class="mt-3 text-xs uppercase"
				style="font-family: var(--font-mono); color: var(--text-tertiary); letter-spacing: 0.08em;"
			>
				{t.insights.sourceLine}
			</p>
		</div>
	</section>

	<!-- Founding Year Timeline -->
	<section class="ds-section mx-auto max-w-4xl px-4 pb-20 sm:px-6 lg:px-8">
		<p
			class="text-xs font-semibold uppercase mb-2"
			style="font-family: var(--font-mono); color: var(--secondary); letter-spacing: 0.12em;"
		>
			{t.insights.foundingKicker}
		</p>
		<SectionLabel text={t.insights.foundingLabel} />
		<h2
			class="mt-3 text-2xl font-bold text-foreground sm:text-3xl"
			style="font-family: var(--font-display);"
		>
			{t.insights.foundingTitle}
		</h2>
		<div class="mt-8">
			<FoundingChart
				client:load
				data={foundingTimeline}
				label={t.insights.startups}
				peakYear={foundingInsight.peakYear}
				peakLabel={foundingPeakLabel}
			/>
		</div>
		<div
			class="mt-8 border-l-2 pl-5 py-1"
			style="border-color: var(--secondary);"
		>
			<p
				class="text-xs font-semibold uppercase mb-2"
				style="font-family: var(--font-mono); color: var(--secondary); letter-spacing: 0.12em;"
			>
				{t.insights.insightTag}
			</p>
			<p
				class="text-lg italic text-foreground leading-relaxed"
				style="font-family: var(--font-body);"
			>
				{foundingInsightText}
			</p>
			<p
				class="mt-3 text-xs uppercase"
				style="font-family: var(--font-mono); color: var(--text-tertiary); letter-spacing: 0.08em;"
			>
				{t.insights.sourceLine}
			</p>
		</div>
	</section>

	<!-- Maturity Distribution -->
	<section class="ds-section mx-auto max-w-4xl px-4 pb-20 sm:px-6 lg:px-8">
		<p
			class="text-xs font-semibold uppercase mb-2"
			style="font-family: var(--font-mono); color: var(--secondary); letter-spacing: 0.12em;"
		>
			{t.insights.maturityKicker}
		</p>
		<SectionLabel text={t.insights.maturityLabel} />
		<h2
			class="mt-3 text-2xl font-bold text-foreground sm:text-3xl"
			style="font-family: var(--font-display);"
		>
			{t.insights.maturityTitle}
		</h2>
		<div class="mt-8">
			<!-- Segmented progress bar: every segment shows its own percent label -->
			<div class="flex w-full overflow-hidden" style="height: 48px;">
				{maturityDistribution.map((m) => (
					<div
						class="relative flex items-center justify-center"
						style={`width: ${m.percentage}%; background: var(--primary); opacity: ${0.3 + (["rd", "prototype", "pilot", "revenue"].indexOf(m.key) * 0.23)};`}
						title={`${m.label.es}: ${m.count} (${m.percentage}%)`}
					>
						<span
							class="text-xs font-semibold"
							style="font-family: var(--font-mono); color: var(--primary-foreground);"
						>
							{m.percentage}%
						</span>
					</div>
				))}
			</div>
			<!-- Legend -->
			<div class="mt-4 flex flex-wrap gap-6">
				{maturityDistribution.map((m) => (
					<div class="flex items-center gap-2">
						<div
							class="h-3 w-3"
							style={`background: var(--primary); opacity: ${0.3 + (["rd", "prototype", "pilot", "revenue"].indexOf(m.key) * 0.23)};`}
						/>
						<span
							class="text-sm text-muted-foreground"
							style="font-family: var(--font-body);"
						>
							{m.label.es}
						</span>
						<span
							class="text-sm font-medium text-foreground"
							style="font-family: var(--font-mono);"
						>
							{m.count}
						</span>
					</div>
				))}
			</div>
		</div>
		<div
			class="mt-8 border-l-2 pl-5 py-1"
			style="border-color: var(--secondary);"
		>
			<p
				class="text-xs font-semibold uppercase mb-2"
				style="font-family: var(--font-mono); color: var(--secondary); letter-spacing: 0.12em;"
			>
				{t.insights.insightTag}
			</p>
			<p
				class="text-lg italic text-foreground leading-relaxed"
				style="font-family: var(--font-body);"
			>
				{maturityInsightText}
			</p>
			<p
				class="mt-3 text-xs uppercase"
				style="font-family: var(--font-mono); color: var(--text-tertiary); letter-spacing: 0.08em;"
			>
				{t.insights.sourceLine}
			</p>
		</div>
	</section>

	<!-- Funding Landscape -->
	<section class="ds-section mx-auto max-w-4xl px-4 pb-20 sm:px-6 lg:px-8">
		<p
			class="text-xs font-semibold uppercase mb-2"
			style="font-family: var(--font-mono); color: var(--secondary); letter-spacing: 0.12em;"
		>
			{t.insights.fundingKicker}
		</p>
		<SectionLabel text={t.insights.fundingLabel} />
		<h2
			class="mt-3 text-2xl font-bold text-foreground sm:text-3xl"
			style="font-family: var(--font-display);"
		>
			{t.insights.fundingTitle}
		</h2>
		<div class="mt-8 grid grid-cols-1 gap-8 sm:grid-cols-3">
			<StatBlock
				value={formatCurrency(fundingStats.totalDisclosed)}
				label={t.insights.fundingTotal}
			/>
			<StatBlock
				value={`${fundingStats.withFunding}/${totalStartups}`}
				label={t.insights.fundingWithData}
			/>
			<StatBlock
				value={formatCurrency(fundingStats.avgFunded)}
				label={t.insights.fundingAvg}
			/>
		</div>
		<div
			class="mt-8 border-l-2 pl-5 py-1"
			style="border-color: var(--secondary);"
		>
			<p
				class="text-xs font-semibold uppercase mb-2"
				style="font-family: var(--font-mono); color: var(--secondary); letter-spacing: 0.12em;"
			>
				{t.insights.insightTag}
			</p>
			<p
				class="text-lg italic text-foreground leading-relaxed"
				style="font-family: var(--font-body);"
			>
				{fundingInsightText}
			</p>
			<p
				class="mt-3 text-xs uppercase"
				style="font-family: var(--font-mono); color: var(--text-tertiary); letter-spacing: 0.08em;"
			>
				{t.insights.sourceLine}
			</p>
		</div>
	</section>

	<!-- PDF Download Gate -->
	<section class="ds-section mx-auto max-w-4xl px-4 pb-20 sm:px-6 lg:px-8">
		<Card variant="featured">
			<div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:gap-8">
				<div class="flex-1">
					<h3
						class="text-xl font-bold text-foreground"
						style="font-family: var(--font-display);"
					>
						{t.insights.pdfTitle}
					</h3>
					<p
						class="mt-1 text-sm text-muted-foreground"
						style="font-family: var(--font-body);"
					>
						{t.insights.pdfSubtitle}
					</p>
					<p
						class="mt-2 text-sm text-muted-foreground"
						style="font-family: var(--font-body);"
					>
						{t.insights.pdfTrust}
					</p>
				</div>
			</div>
			<div class="mt-6">
				<PdfDownloadForm
					client:visible
					translations={{
						nameLabel: t.insights.pdfNameLabel,
						namePlaceholder: t.insights.pdfNamePlaceholder,
						emailLabel: t.insights.pdfEmailLabel,
						emailPlaceholder: t.insights.pdfEmailPlaceholder,
						submit: t.insights.pdfSubmit,
						success: t.insights.pdfSuccess,
						privacy: t.insights.pdfPrivacy,
						required: t.insights.pdfRequired,
						invalidEmail: t.insights.pdfInvalidEmail,
						error: t.insights.pdfError,
					}}
				/>
			</div>
		</Card>
	</section>

	<!-- Corporate CTA -->
	<section class="ds-section mx-auto max-w-4xl px-4 pb-20 text-center sm:px-6 lg:px-8">
		<h2
			class="text-2xl font-bold text-foreground sm:text-3xl"
			style="font-family: var(--font-display);"
		>
			{t.insights.ctaTitle}
		</h2>
		<div class="mt-6 flex justify-center">
			<CorporateCta locale={locale} />
		</div>
	</section>
</BaseLayout>
