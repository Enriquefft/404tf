---
import { FoundingChart } from "@/components/charts/founding-chart";
import { GeoChart } from "@/components/charts/geo-chart";
import { VerticalChart } from "@/components/charts/vertical-chart";
import CorporateCta from "@/components/corporate-cta.astro";
import { PdfDownloadForm } from "@/components/pdf-download-form";
import Card from "@/components/ui/card.astro";
import SectionLabel from "@/components/ui/section-label.astro";
import StatBlock from "@/components/ui/stat-block.astro";
import { getTranslations } from "@/i18n/translations";
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
	countryCount,
	countryDistribution,
	formatCurrency,
	foundingTimeline,
	fundingStats,
	maturityDistribution,
	totalStartups,
	verticalDistribution,
} from "@/lib/insights-data";

const locale = "es" as const;
const t = getTranslations(locale);
---

<BaseLayout
	title={`${t.insights.title} — ${t.meta.siteTitle}`}
	description={t.insights.subtitle}
	locale={locale}
>
	<!-- Header -->
	<section class="ds-section mx-auto max-w-4xl px-4 py-20 text-center sm:px-6 lg:px-8">
		<p
			class="text-xs font-semibold uppercase text-muted-foreground tracking-widest mb-4"
			style="font-family: var(--font-heading);"
		>
			{t.insights.byline}
		</p>
		<h1
			class="text-4xl font-bold tracking-tight text-foreground sm:text-5xl lg:text-6xl"
			style="font-family: var(--font-display);"
		>
			{t.insights.title}
		</h1>
		<p
			class="mt-6 text-lg text-muted-foreground leading-relaxed max-w-2xl mx-auto"
			style="font-family: var(--font-body);"
		>
			{t.insights.subtitle}
		</p>
	</section>

	<!-- Executive Summary -->
	<section class="ds-section mx-auto max-w-4xl px-4 pb-20 sm:px-6 lg:px-8">
		<div class="grid grid-cols-1 gap-8 sm:grid-cols-3">
			<div class="text-center">
				<StatBlock value={`${totalStartups}+`} label={t.insights.execStartups} size="hero" />
			</div>
			<div class="text-center">
				<StatBlock value={`${countryCount}`} label={t.insights.execCountries} size="hero" />
			</div>
			<div class="text-center">
				<StatBlock
					value={formatCurrency(fundingStats.totalDisclosed)}
					label={t.insights.execFunding}
					size="hero"
				/>
			</div>
		</div>
	</section>

	<!-- Geographic Distribution -->
	<section class="ds-section mx-auto max-w-4xl px-4 pb-20 sm:px-6 lg:px-8">
		<SectionLabel text={t.insights.geoLabel} />
		<h2
			class="mt-3 text-2xl font-bold text-foreground sm:text-3xl"
			style="font-family: var(--font-display);"
		>
			{t.insights.geoTitle}
		</h2>
		<div class="mt-8">
			<GeoChart
				client:visible
				data={countryDistribution}
				directoryPath="/es/directorio"
			/>
		</div>
	</section>

	<!-- Vertical Breakdown -->
	<section class="ds-section mx-auto max-w-4xl px-4 pb-20 sm:px-6 lg:px-8">
		<SectionLabel text={t.insights.verticalLabel} />
		<h2
			class="mt-3 text-2xl font-bold text-foreground sm:text-3xl"
			style="font-family: var(--font-display);"
		>
			{t.insights.verticalTitle}
		</h2>
		<div class="mt-8">
			<VerticalChart
				client:visible
				data={verticalDistribution}
				locale={locale}
				directoryPath="/es/directorio"
			/>
		</div>
	</section>

	<!-- Founding Year Timeline -->
	<section class="ds-section mx-auto max-w-4xl px-4 pb-20 sm:px-6 lg:px-8">
		<SectionLabel text={t.insights.foundingLabel} />
		<h2
			class="mt-3 text-2xl font-bold text-foreground sm:text-3xl"
			style="font-family: var(--font-display);"
		>
			{t.insights.foundingTitle}
		</h2>
		<div class="mt-8">
			<FoundingChart
				client:visible
				data={foundingTimeline}
				label={t.insights.startups}
			/>
		</div>
	</section>

	<!-- Maturity Distribution -->
	<section class="ds-section mx-auto max-w-4xl px-4 pb-20 sm:px-6 lg:px-8">
		<SectionLabel text={t.insights.maturityLabel} />
		<h2
			class="mt-3 text-2xl font-bold text-foreground sm:text-3xl"
			style="font-family: var(--font-display);"
		>
			{t.insights.maturityTitle}
		</h2>
		<div class="mt-8">
			<!-- Segmented progress bar -->
			<div class="flex w-full overflow-hidden rounded-[var(--radius-md)]" style="height: 40px;">
				{maturityDistribution.map((m) => (
					<div
						class="relative flex items-center justify-center"
						style={`width: ${m.percentage}%; background: var(--primary); opacity: ${0.3 + (["rd", "prototype", "pilot", "revenue"].indexOf(m.key) * 0.23)};`}
						title={`${m.label.es}: ${m.count} (${m.percentage}%)`}
					>
						{m.percentage >= 10 && (
							<span
								class="text-xs font-semibold text-white"
								style="font-family: var(--font-mono);"
							>
								{m.percentage}%
							</span>
						)}
					</div>
				))}
			</div>
			<!-- Legend -->
			<div class="mt-4 flex flex-wrap gap-6">
				{maturityDistribution.map((m) => (
					<div class="flex items-center gap-2">
						<div
							class="h-3 w-3 rounded-sm"
							style={`background: var(--primary); opacity: ${0.3 + (["rd", "prototype", "pilot", "revenue"].indexOf(m.key) * 0.23)};`}
						/>
						<span
							class="text-sm text-muted-foreground"
							style="font-family: var(--font-body);"
						>
							{m.label.es}
						</span>
						<span
							class="text-sm font-medium text-foreground"
							style="font-family: var(--font-mono);"
						>
							{m.count}
						</span>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Funding Landscape -->
	<section class="ds-section mx-auto max-w-4xl px-4 pb-20 sm:px-6 lg:px-8">
		<SectionLabel text={t.insights.fundingLabel} />
		<h2
			class="mt-3 text-2xl font-bold text-foreground sm:text-3xl"
			style="font-family: var(--font-display);"
		>
			{t.insights.fundingTitle}
		</h2>
		<div class="mt-8 grid grid-cols-1 gap-8 sm:grid-cols-3">
			<StatBlock
				value={formatCurrency(fundingStats.totalDisclosed)}
				label={t.insights.fundingTotal}
			/>
			<StatBlock
				value={`${fundingStats.withFunding}/${totalStartups}`}
				label={t.insights.fundingWithData}
			/>
			<StatBlock
				value={formatCurrency(fundingStats.avgFunded)}
				label={t.insights.fundingAvg}
			/>
		</div>
	</section>

	<!-- PDF Download Gate -->
	<section class="ds-section mx-auto max-w-4xl px-4 pb-20 sm:px-6 lg:px-8">
		<Card variant="featured">
			<div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:gap-8">
				<div class="flex-1">
					<h3
						class="text-xl font-bold text-foreground"
						style="font-family: var(--font-display);"
					>
						{t.insights.pdfTitle}
					</h3>
					<p
						class="mt-1 text-sm text-muted-foreground"
						style="font-family: var(--font-body);"
					>
						{t.insights.pdfSubtitle}
					</p>
					<p
						class="mt-2 text-sm text-muted-foreground"
						style="font-family: var(--font-body);"
					>
						{t.insights.pdfTrust}
					</p>
				</div>
			</div>
			<div class="mt-6">
				<PdfDownloadForm
					client:visible
					translations={{
						nameLabel: t.insights.pdfNameLabel,
						namePlaceholder: t.insights.pdfNamePlaceholder,
						emailLabel: t.insights.pdfEmailLabel,
						emailPlaceholder: t.insights.pdfEmailPlaceholder,
						submit: t.insights.pdfSubmit,
						success: t.insights.pdfSuccess,
						privacy: t.insights.pdfPrivacy,
						required: t.insights.pdfRequired,
						invalidEmail: t.insights.pdfInvalidEmail,
						error: t.insights.pdfError,
					}}
				/>
			</div>
		</Card>
	</section>

	<!-- Corporate CTA -->
	<section class="ds-section mx-auto max-w-4xl px-4 pb-20 text-center sm:px-6 lg:px-8">
		<h2
			class="text-2xl font-bold text-foreground sm:text-3xl"
			style="font-family: var(--font-display);"
		>
			{t.insights.ctaTitle}
		</h2>
		<div class="mt-6 flex justify-center">
			<CorporateCta locale={locale} />
		</div>
	</section>
</BaseLayout>
