---
import { CountryBarChart } from "@/components/country-bar-chart";
import FadeInSection from "@/components/fade-in-section.astro";
import SectionLabel from "@/components/ui/section-label.astro";
import type { Locale } from "@/i18n/translations";

type Props = {
	locale: Locale;
	label: string;
	headline: string;
	topCountriesLabel: string;
	linkText: string;
	insightsHref: string;
	statBiotechOrAi: string;
	statPilotStage: string;
	statFromPeru: string;
};

const {
	label,
	headline,
	topCountriesLabel,
	linkText,
	insightsHref,
	statBiotechOrAi,
	statPilotStage,
	statFromPeru,
} = Astro.props;

const countryData = [
	{ country: "Peru", count: 32 },
	{ country: "Argentina", count: 8 },
	{ country: "Chile", count: 4 },
	{ country: "Mexico", count: 2 },
	{ country: "Colombia", count: 2 },
];
---

<FadeInSection class="py-20 sm:py-28">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="mb-10">
			<SectionLabel text={label} />
			<h2
				class="mt-3 text-3xl font-bold tracking-tight text-foreground sm:text-4xl"
				style="font-family: var(--font-heading);"
			>
				{headline}
			</h2>
		</div>

		<div class="grid gap-10 lg:grid-cols-2">
			<!-- Left: Bar chart -->
			<div
				class="rounded-lg border p-6"
				style="background: var(--card); border-color: var(--border-subtle);"
			>
				<CountryBarChart client:visible data={countryData} title={topCountriesLabel} />
			</div>

			<!-- Right: 3 key stats -->
			<div class="flex flex-col justify-center gap-6">
				<div
					class="rounded-lg border p-6"
					style="background: var(--card); border-color: var(--border-subtle);"
				>
					<span
						class="text-4xl font-semibold tracking-tight tabular-nums"
						style="font-family: var(--font-mono); color: var(--foreground);"
					>
						64%
					</span>
					<p
						class="mt-1 text-sm text-muted-foreground"
						style="font-family: var(--font-body);"
					>
						{statBiotechOrAi}
					</p>
				</div>

				<div
					class="rounded-lg border p-6"
					style="background: var(--card); border-color: var(--border-subtle);"
				>
					<span
						class="text-4xl font-semibold tracking-tight tabular-nums"
						style="font-family: var(--font-mono); color: var(--foreground);"
					>
						44%
					</span>
					<p
						class="mt-1 text-sm text-muted-foreground"
						style="font-family: var(--font-body);"
					>
						{statPilotStage}
					</p>
				</div>

				<div
					class="rounded-lg border p-6"
					style="background: var(--card); border-color: var(--border-subtle);"
				>
					<span
						class="text-4xl font-semibold tracking-tight tabular-nums"
						style="font-family: var(--font-mono); color: var(--foreground);"
					>
						32
					</span>
					<p
						class="mt-1 text-sm text-muted-foreground"
						style="font-family: var(--font-body);"
					>
						{statFromPeru}
					</p>
				</div>
			</div>
		</div>

		<div class="mt-8 text-center">
			<a
				href={insightsHref}
				class="inline-flex items-center gap-2 text-sm font-medium text-primary transition-colors duration-150 hover:text-foreground"
				style="font-family: var(--font-heading);"
			>
				{linkText}
				<svg
					width="16"
					height="16"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
				>
					<path d="M9 5l6 7-6 7" />
				</svg>
			</a>
		</div>
	</div>
</FadeInSection>
