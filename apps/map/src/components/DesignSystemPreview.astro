				</div>

				<!-- Subtle border -->
				<div>
					<h3 class="mb-4 mt-8" style="font-family: var(--font-heading); font-size: 1rem; font-weight: 600; color: var(--muted-foreground); letter-spacing: 0.02em;">Subtle Border</h3>
