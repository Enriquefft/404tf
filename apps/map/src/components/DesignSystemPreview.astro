					</span>
				</div>

				<!-- Bar chart -->
				<div class="flex items-end gap-2" style="height: 200px;">
					{BAR_DATA.map((bar, i) => {
						const heightPct = (bar.value / BAR_MAX) * 100;
						return (
							<div class="flex flex-1 flex-col items-center gap-2">
