---
import type { Locale } from "@/i18n/translations";
import { getTranslations } from "@/i18n/translations";
import { getAlternateLocale, getAlternateLocalePath, getRouteHref } from "@/i18n/utils";

type Props = {
	locale: Locale;
};

const { locale } = Astro.props;
const t = getTranslations(locale);
const altLocale = getAlternateLocale(locale);
const currentPath = Astro.url.pathname;
const altPath = getAlternateLocalePath(currentPath, altLocale);

const navLinks = [
	{ label: t.nav.directory, href: getRouteHref("directory", locale) },
	{ label: t.nav.insights, href: getRouteHref("insights", locale) },
	{ label: t.nav.startups, href: getRouteHref("startups", locale) },
] as const;

function isActive(href: string): boolean {
	const normalized = currentPath.replace(/\/$/, "");
	return normalized === href || normalized.startsWith(`${href}/`);
}
---

<nav
	class="fixed top-0 right-0 left-0 z-20 border-b border-border-subtle bg-[var(--nav-bg,var(--background))]/80 backdrop-blur-md transition-colors duration-150"
>
	<div class="mx-auto flex h-14 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
		<!-- Logo -->
		<a
			href={`/${locale}`}
			class="font-[var(--font-display)] text-lg font-semibold tracking-tight text-foreground"
			style="font-family: var(--font-display);"
		>
			404 Mapped
		</a>

		<!-- Desktop links -->
		<div class="hidden items-center gap-6 md:flex">
			{
				navLinks.map((link) => (
					<a
						href={link.href}
						class:list={[
							"text-sm transition-colors duration-150",
							isActive(link.href)
								? "font-medium text-primary"
								: "text-muted-foreground hover:text-foreground",
						]}
					>
						{link.label}
					</a>
				))
			}

			<!-- Language toggle -->
			<a
				href={altPath}
				class="ml-2 rounded-sm px-2 py-1 text-xs font-medium uppercase tracking-wider text-muted-foreground transition-colors duration-150 hover:text-foreground"
			>
				{locale === "es" ? "EN" : "ES"}
			</a>
		</div>

		<!-- Mobile hamburger (CSS-only via <details>) -->
		<details class="group relative md:hidden">
			<summary
				class="flex h-8 w-8 cursor-pointer list-none items-center justify-center text-muted-foreground hover:text-foreground"
				aria-label={t.nav.openMenu}
			>
				<!-- Hamburger icon (visible when closed) -->
				<svg
					class="h-5 w-5 group-open:hidden"
					fill="none"
					viewBox="0 0 24 24"
					stroke="currentColor"
					stroke-width="2"
					aria-hidden="true"
				>
					<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
				</svg>
				<!-- Close icon (visible when open) -->
				<svg
					class="hidden h-5 w-5 group-open:block"
					fill="none"
					viewBox="0 0 24 24"
					stroke="currentColor"
					stroke-width="2"
					aria-hidden="true"
				>
					<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
				</svg>
			</summary>

			<div
				class="absolute right-0 top-full mt-2 w-48 rounded-md border border-border-subtle bg-card p-3 shadow-lg"
			>
				{
					navLinks.map((link) => (
						<a
							href={link.href}
							class:list={[
								"block rounded-sm px-3 py-2 text-sm transition-colors duration-150",
								isActive(link.href)
									? "font-medium text-primary"
									: "text-muted-foreground hover:text-foreground",
							]}
						>
							{link.label}
						</a>
					))
				}
				<hr class="my-2 border-border-subtle" />
				<a
					href={altPath}
					class="block px-3 py-2 text-sm font-medium uppercase tracking-wider text-muted-foreground transition-colors duration-150 hover:text-foreground"
				>
					{locale === "es" ? "EN — English" : "ES — Español"}
				</a>
			</div>
		</details>
	</div>
</nav>
