---
/**
 * Social Proof Bar — "Working with" row of placeholder wordmarks.
 *
 * No fabricated logos. Each slot is a generic SVG wordmark rendered from a
 * letterform pair so the bar communicates "partners live here" without
 * implying a partnership we don't have. Swap in real brand marks later by
 * replacing the placeholder set.
 */
import SectionLabel from "@/components/ui/section-label.astro";
import type { Locale } from "@/i18n/translations";

type Props = {
	locale: Locale;
	backedByLabel: string;
	pressLabel: string;
};

const { backedByLabel, pressLabel } = Astro.props;

// Generic initials — visibly placeholder, not mistakable for real brand marks.
const partnerSlots = ["ACME", "NOVA", "ORBIT", "MERIDIAN", "FORGE", "ATLAS"] as const;
const pressSlots = ["PRESS", "MEDIA", "REVIEW", "JOURNAL"] as const;
---

<section
	aria-label="Partners and press (placeholder)"
	class="py-16 sm:py-20"
	style="background: var(--background);"
>
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<!-- Backed by / Working with row -->
		<div class="flex flex-col items-center gap-6">
			<span
				class="text-[11px] font-medium uppercase"
				style="font-family: var(--font-mono); color: var(--secondary); letter-spacing: 0.18em;"
			>
				{backedByLabel}
			</span>

			<ul
				class="flex w-full flex-wrap items-center justify-center gap-x-8 gap-y-5 sm:gap-x-12"
			>
				{
					partnerSlots.map((name) => (
						<li class="flex items-center justify-center">
							<svg
								viewBox="0 0 100 40"
								width="100"
								height="40"
								role="img"
								aria-label={`${name} placeholder wordmark`}
								class="opacity-60 transition-opacity duration-200 hover:opacity-100"
							>
								<title>{`${name} — placeholder wordmark`}</title>
								<rect
									x="0.5"
									y="0.5"
									width="99"
									height="39"
									fill="transparent"
									stroke="var(--border-subtle)"
									stroke-width="1"
								/>
								<text
									x="50"
									y="25"
									text-anchor="middle"
									fill="var(--muted-foreground)"
									style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.16em; font-weight: 500;"
								>
									{name}
								</text>
							</svg>
						</li>
					))
				}
			</ul>
		</div>

		<!-- Divider -->
		<div
			class="mx-auto my-12 h-px w-24"
			style="background: var(--border-subtle);"
			aria-hidden="true"
		>
		</div>

		<!-- Press / "As seen in" row (kept intentionally generic) -->
		<div class="flex flex-col items-center gap-6">
			<SectionLabel text={pressLabel} />

			<ul
				class="flex w-full flex-wrap items-center justify-center gap-x-8 gap-y-5 sm:gap-x-12"
			>
				{
					pressSlots.map((name) => (
						<li class="flex items-center justify-center">
							<svg
								viewBox="0 0 120 40"
								width="120"
								height="40"
								role="img"
								aria-label={`${name} placeholder wordmark`}
								class="opacity-50 transition-opacity duration-200 hover:opacity-80"
							>
								<title>{`${name} — placeholder wordmark`}</title>
								<text
									x="60"
									y="26"
									text-anchor="middle"
									fill="var(--muted-foreground)"
									style="font-family: var(--font-display); font-size: 20px; letter-spacing: 0.04em; font-weight: 600;"
								>
									{name}
								</text>
							</svg>
						</li>
					))
				}
			</ul>
		</div>
	</div>
</section>
