---
import Badge from "@/components/ui/badge.astro";
import { getTranslations, type Locale } from "@/i18n/translations";
import { getCountryFlag } from "@/lib/countries";
import { formatCurrency, parseFunding } from "@/lib/db-queries";
import type { MaturityKey, VerticalKey } from "@/lib/startup-schema";
import { VERTICAL_CONFIG } from "@/lib/verticals";

type StartupData = {
	slug: string;
	name: string;
	one_liner: string | null;
	country: string;
	country_es: string;
	city: string;
	verticals: readonly VerticalKey[];
	maturity_level: MaturityKey;
	funding_received: string | null;
};

type EditorialTag = {
	text: string;
	tone: "accent" | "muted";
};

type Props = {
	startup: StartupData;
	locale: Locale;
	href: string;
	editorial_tag?: EditorialTag;
};

const { startup, locale, href, editorial_tag } = Astro.props;
const t = getTranslations(locale);

const firstVertical: VerticalKey | undefined = startup.verticals[0];
const accentColor = firstVertical
	? (VERTICAL_CONFIG[firstVertical]?.color ?? "var(--v-other)")
	: "var(--v-other)";

const initial = startup.name.charAt(0).toUpperCase();
const flag = getCountryFlag(startup.country);
const displayCountry = locale === "es" ? startup.country_es : startup.country;

// Show only the primary vertical on the card — additional verticals are
// signalled by the accent color and the editorial tag. Keeps the card
// hierarchy clean (identity → pitch → signal → traction → tag).
const primaryVertical: VerticalKey | undefined = startup.verticals[0];

// Traction metric: parse the raw seed string and re-format through the
// canonical formatCurrency helper so every surface renders the same value.
const fundingAmount = parseFunding(startup.funding_received);
const fundingDisplay = fundingAmount !== null ? formatCurrency(fundingAmount) : null;

// Editorial tag: explicit override takes precedence, otherwise derive
// automatically from maturity + funding disclosure. Priority order:
//   1. pilot → READY FOR PILOT (amber accent — strongest conversion signal)
//   2. no disclosed funding → IN STEALTH (muted)
//   3. rd / prototype → EARLY STAGE (muted)
//   4. revenue → RAISED (muted — traction already shown via $)
const derivedTag: EditorialTag | null = (() => {
	if (startup.maturity_level === "pilot") {
		return { text: t.startupCard.tagReadyForPilot, tone: "accent" };
	}
	if (startup.funding_received === null) {
		return { text: t.startupCard.tagInStealth, tone: "muted" };
	}
	if (startup.maturity_level === "rd" || startup.maturity_level === "prototype") {
		return { text: t.startupCard.tagEarlyStage, tone: "muted" };
	}
	return null;
})();

const tag: EditorialTag | null = editorial_tag ?? derivedTag;
---

<a
	href={href}
	class="startup-card group relative flex h-full flex-col bg-card transition-[border-color,transform] duration-200 ease-out hover:-translate-y-0.5"
	style={`--_accent: ${accentColor};`}
>
	<!-- Accent rail — thin vertical stripe in vertical color, keeps the
	     visual signal even before hover. -->
	<span
		class="pointer-events-none absolute inset-y-0 left-0 w-[2px]"
		style={`background: ${accentColor};`}
		aria-hidden="true"
	></span>

	<!-- Head row: logo, name + status -->
	<div class="flex items-start gap-3 px-5 pt-5">
		<!-- Sharp avatar block (2px micro-radius for optical softness) -->
		<div
			class="flex h-11 w-11 shrink-0 items-center justify-center rounded-[2px] text-base"
			style={`background: ${accentColor}; font-family: var(--font-display); font-weight: 700; color: var(--background);`}
		>
			{initial}
		</div>

		<div class="flex-1 min-w-0">
			<h3
				class="truncate text-[18px] font-semibold leading-tight text-foreground"
				style="font-family: var(--font-heading);"
			>
				{startup.name}
			</h3>
			<div
				class="mt-1 flex items-center gap-1.5 text-[11px] uppercase text-[var(--text-tertiary)]"
				style="font-family: var(--font-mono); letter-spacing: 0.08em;"
			>
				{flag && <span aria-hidden="true" class="text-sm">{flag}</span>}
				<span class="truncate">{startup.city}, {displayCountry}</span>
			</div>
		</div>

		<!-- Arrow affordance — shifts on hover -->
		<div
			class="mt-1 shrink-0 text-[var(--text-tertiary)] transition-transform duration-200 ease-out group-hover:translate-x-0.5 group-hover:text-foreground"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				width="16"
				height="16"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="1.5"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"
			>
				<path d="M9 5l6 7-6 7"></path>
			</svg>
		</div>
	</div>

	<!-- Pitch -->
	<p
		class="mt-3 flex-1 px-5 text-[14px] leading-relaxed text-muted-foreground line-clamp-3"
		style="font-family: var(--font-body);"
	>
		{startup.one_liner}
	</p>

	<!-- Traction + signal row -->
	<div class="mt-4 flex items-end justify-between gap-3 px-5">
		<div class="min-w-0">
			{
				fundingDisplay ? (
					<div
						class="truncate text-[13px] tabular-nums"
						style="font-family: var(--font-mono); color: var(--foreground); font-weight: 600;"
					>
						{fundingDisplay}{" "}
						<span
							class="text-[11px] uppercase text-[var(--text-tertiary)]"
							style="letter-spacing: 0.08em; font-weight: 500;"
						>
							{t.startupCard.raised}
						</span>
					</div>
				) : (
					<div
						class="text-[11px] uppercase text-[var(--text-tertiary)]"
						style="font-family: var(--font-mono); letter-spacing: 0.08em;"
					>
						&nbsp;
					</div>
				)
			}
		</div>
		{
			tag && (
				<span
					class="shrink-0 px-2 py-0.5 text-[10px] uppercase"
					style={`font-family: var(--font-mono); letter-spacing: 0.1em; font-weight: 600; border: 1px solid ${
						tag.tone === "accent"
							? "color-mix(in oklch, var(--primary) 45%, transparent)"
							: "var(--border-subtle)"
					}; color: ${tag.tone === "accent" ? "var(--primary)" : "var(--text-tertiary)"}; background: ${
						tag.tone === "accent"
							? "color-mix(in oklch, var(--primary) 8%, transparent)"
							: "transparent"
					};`}
				>
					{tag.text}
				</span>
			)
		}
	</div>

	<!-- Footer strip: primary vertical + maturity, divider on top -->
	<div
		class="mt-4 flex flex-wrap items-center gap-2 border-t px-5 py-3"
		style="border-color: var(--border-subtle);"
	>
		{primaryVertical && <Badge variant="vertical" value={primaryVertical} locale={locale} />}
		<Badge variant="maturity" value={startup.maturity_level} locale={locale} />
	</div>
</a>

<style>
	.startup-card {
		border: 1px solid var(--border-subtle);
		border-radius: 0;
	}
	.startup-card:hover {
		border-color: var(--primary);
	}
</style>
