---
import Badge from "@/components/ui/badge.astro";
import Card from "@/components/ui/card.astro";
import type { Locale } from "@/i18n/translations";
import { getCountryFlag } from "@/lib/countries";
import type { VerticalKey } from "@/lib/verticals";
import { VERTICAL_CONFIG } from "@/lib/verticals";

type StartupData = {
	slug: string;
	name: string;
	one_liner: string;
	country: string;
	country_es: string;
	city: string;
	verticals: string[];
	maturity_level: string;
	funding_received: string | null;
};

type Props = {
	startup: StartupData;
	locale: Locale;
	href: string;
};

const { startup, locale, href } = Astro.props;

const firstVertical = startup.verticals[0] as VerticalKey | undefined;
const initialsColor = firstVertical
	? (VERTICAL_CONFIG[firstVertical]?.color ?? "var(--v-other)")
	: "var(--v-other)";

const initial = startup.name.charAt(0).toUpperCase();

const flag = getCountryFlag(startup.country);

const displayCountry = locale === "es" ? startup.country_es : startup.country;

const visibleVerticals = startup.verticals.slice(0, 2);
const remainingCount = startup.verticals.length - 2;

const accentColor = firstVertical
	? (VERTICAL_CONFIG[firstVertical]?.color ?? "var(--border-strong)")
	: "var(--border-strong)";
---

<div
	class="startup-card-wrapper"
	style={`--_accent: ${accentColor};`}
>
<Card
	href={href}
	class="group relative hover:-translate-y-0.5 transition-transform duration-200 ease-out"
>
	<div class="flex items-start gap-4">
		<!-- Initials circle -->
		<div
			class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full text-sm font-semibold text-white"
			style={`background: ${initialsColor}; font-family: var(--font-heading);`}
		>
			{initial}
		</div>

		<!-- Content -->
		<div class="flex-1 min-w-0">
			<!-- Name -->
			<h3
				class="text-base font-semibold text-foreground leading-tight"
				style="font-family: var(--font-heading);"
			>
				{startup.name}
			</h3>

			<!-- One-liner -->
			<p
				class="mt-1.5 text-sm text-muted-foreground line-clamp-2 leading-relaxed"
				style="font-family: var(--font-body);"
			>
				{startup.one_liner}
			</p>

			<!-- Bottom metadata row -->
			<div class="mt-3 flex flex-wrap items-center gap-2">
				<!-- Location -->
				<span
					class="inline-flex items-center gap-1 text-xs text-[var(--text-tertiary)]"
					style="font-family: var(--font-body);"
				>
					{flag && <span aria-hidden="true">{flag}</span>}
					{startup.city}, {displayCountry}
				</span>

				<span class="text-[var(--border-strong)]" aria-hidden="true">&middot;</span>

				<!-- Vertical pills -->
				{
					visibleVerticals.map((v) => (
						<Badge variant="vertical" value={v} locale={locale} />
					))
				}
				{
					remainingCount > 0 && (
						<span
							class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-muted text-muted-foreground"
							style="font-family: var(--font-heading);"
						>
							+{remainingCount}
						</span>
					)
				}

				<span class="text-[var(--border-strong)]" aria-hidden="true">&middot;</span>

				<!-- Maturity badge -->
				<Badge variant="maturity" value={startup.maturity_level} locale={locale} />

				<!-- Funding -->
				{
					startup.funding_received && (
						<>
							<span class="text-[var(--border-strong)]" aria-hidden="true">
								&middot;
							</span>
							<span
								class="text-xs text-[var(--text-tertiary)]"
								style="font-family: var(--font-mono);"
							>
								{startup.funding_received}
							</span>
						</>
					)
				}
			</div>
		</div>

		<!-- Arrow icon -->
		<div class="flex shrink-0 items-center self-center text-[var(--text-tertiary)] group-hover:text-foreground transition-colors duration-150">
			<!-- Solar: Alt Arrow Right Linear -->
			<svg
				xmlns="http://www.w3.org/2000/svg"
				width="18"
				height="18"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="1.5"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"
			>
				<path d="M9 5l6 7-6 7" />
			</svg>
		</div>
	</div>

</Card>
</div>

<style>
	.startup-card-wrapper :global(a:hover) {
		border-color: var(--_accent) !important;
	}
</style>
