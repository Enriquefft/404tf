---
type Props = {
	label: string;
	name: string;
	type?: "text" | "email" | "url" | "tel";
	placeholder?: string;
	required?: boolean;
	error?: string;
	id?: string;
};

const { label, name, type = "text", placeholder, required = false, error, id } = Astro.props;

const inputId = id ?? `input-${name}`;
const hasError = Boolean(error);
---

<div class="flex flex-col">
	<label
		for={inputId}
		class="mb-1.5 text-sm font-medium text-muted-foreground"
		style="font-family: var(--font-heading);"
	>
		{label}
		{required && <span class="text-destructive ml-0.5">*</span>}
	</label>
	<input
		id={inputId}
		name={name}
		type={type}
		placeholder={placeholder}
		required={required}
		class:list={[
			"bg-[var(--background)] border rounded-[var(--radius-md)] px-3.5 py-2.5",
			"text-foreground placeholder:text-[var(--text-tertiary)]",
			"transition-colors duration-150",
			"focus:border-primary focus:ring-2 focus:ring-[var(--primary-25)] focus:outline-none",
			hasError ? "border-destructive" : "border-input",
		]}
		style="font-family: var(--font-body);"
	/>
	{
		error && (
			<p
				class="mt-1 text-sm text-destructive"
				style="font-family: var(--font-body);"
				role="alert"
			>
				{error}
			</p>
		)
	}
</div>
