---
type Props = {
	variant?: "default" | "featured" | "compact";
	href?: string;
	class?: string;
};

const { variant = "default", href, class: className = "" } = Astro.props;

const variantStyles: Record<string, string> = {
	default: "bg-card border border-[var(--border-subtle)] rounded-[var(--radius)] p-6",
	featured: "bg-card border border-[var(--primary-25)] rounded-[var(--radius-lg)] p-8",
	compact: "bg-card border border-[var(--border-subtle)] rounded-[var(--radius-md)] p-3",
};

const hoverStyles = href ? "hover:border-[var(--border-strong)] hover:bg-popover" : "";

const featuredShadow = variant === "featured" ? "shadow-[var(--glow-primary)]" : "";

const baseStyles = [variantStyles[variant], featuredShadow, hoverStyles, className]
	.filter(Boolean)
	.join(" ");
---

{
	href ? (
		<a
			href={href}
			class={baseStyles}
			style="transition: border-color 200ms ease-out, background-color 200ms ease-out;"
		>
			<slot />
		</a>
	) : (
		<div class={baseStyles}>
			<slot />
		</div>
	)
}
