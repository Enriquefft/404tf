---
import type { Locale } from "@/i18n/translations";
import type { MaturityKey, VerticalKey } from "@/lib/startup-schema";
import { MATURITY_CONFIG, VERTICAL_CONFIG } from "@/lib/verticals";

type Props = {
	variant: "vertical" | "maturity" | "status";
	value: string;
	label?: string;
	locale?: Locale;
};

const { variant, value, label, locale = "es" } = Astro.props;

function isVerticalKey(k: string): k is VerticalKey {
	return Object.hasOwn(VERTICAL_CONFIG, k);
}

function isMaturityKey(k: string): k is MaturityKey {
	return Object.hasOwn(MATURITY_CONFIG, k);
}

function getVerticalStyles(key: string): {
	bg: string;
	color: string;
	dot: string;
} {
	if (!isVerticalKey(key)) {
		return {
			bg: VERTICAL_CONFIG.other.muted,
			color: VERTICAL_CONFIG.other.color,
			dot: VERTICAL_CONFIG.other.color,
		};
	}
	const config = VERTICAL_CONFIG[key];
	return { bg: config.muted, color: config.color, dot: config.color };
}

function getVerticalLabel(key: string): string {
	if (label) return label;
	if (!isVerticalKey(key)) return key;
	return VERTICAL_CONFIG[key].label[locale];
}

function getMaturityLabel(key: string): string {
	if (label) return label;
	if (!isMaturityKey(key)) return key;
	return MATURITY_CONFIG[key].label[locale];
}

const isVertical = variant === "vertical";
const isMaturity = variant === "maturity";

const verticalStyles = isVertical ? getVerticalStyles(value) : null;
const displayLabel = isVertical
	? getVerticalLabel(value)
	: isMaturity
		? getMaturityLabel(value)
		: (label ?? value);
---

{
	isVertical && verticalStyles ? (
		<span
			class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-0.5 text-xs font-medium"
			style={`font-family: var(--font-heading); background: ${verticalStyles.bg}; color: ${verticalStyles.color};`}
		>
			<span
				class="inline-block h-1.5 w-1.5 rounded-full shrink-0"
				style={`background: ${verticalStyles.dot};`}
				aria-hidden="true"
			/>
			{displayLabel}
		</span>
	) : (
		<span
			class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-muted text-muted-foreground"
			style="font-family: var(--font-heading);"
		>
			{displayLabel}
		</span>
	)
}
