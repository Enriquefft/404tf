---
type Props = {
	value: string;
	label: string;
	size?: "default" | "hero";
};

const { value, label, size = "default" } = Astro.props;

const isHero = size === "hero";
---

<div class="flex flex-col">
	<span
		class:list={[
			"font-medium leading-tight",
			isHero ? "text-5xl tracking-tight" : "text-2xl",
		]}
		style={isHero
			? "font-family: var(--font-mono); letter-spacing: -0.01em; color: var(--foreground); font-variant-numeric: tabular-nums;"
			: "font-family: var(--font-mono);"}
	>
		{value}
	</span>
	<span
		class:list={[
			"text-muted-foreground",
			isHero ? "text-sm mt-2" : "text-xs mt-1",
		]}
		style="font-family: var(--font-heading);"
	>
		{label}
	</span>
</div>
