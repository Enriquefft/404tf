---
type Props = {
	label: string;
	name: string;
	placeholder?: string;
	required?: boolean;
	error?: string;
	id?: string;
	rows?: number;
	maxlength?: number;
};

const { label, name, placeholder, required = false, error, id, rows = 4, maxlength } = Astro.props;

const textareaId = id ?? `textarea-${name}`;
const hasError = Boolean(error);
---

<div class="flex flex-col">
	<label
		for={textareaId}
		class="mb-1.5 text-sm font-medium text-muted-foreground"
		style="font-family: var(--font-heading);"
	>
		{label}
		{required && <span class="text-destructive ml-0.5">*</span>}
	</label>
	<textarea
		id={textareaId}
		name={name}
		placeholder={placeholder}
		required={required}
		rows={rows}
		maxlength={maxlength}
		class:list={[
			"bg-[var(--background)] border rounded-[var(--radius-md)] px-3.5 py-2.5",
			"text-foreground placeholder:text-[var(--text-tertiary)]",
			"transition-colors duration-150 resize-y",
			"focus:border-primary focus:ring-2 focus:ring-[var(--primary-25)] focus:outline-none",
			hasError ? "border-destructive" : "border-input",
		]}
		style="font-family: var(--font-body);"
	/>
	<div class="flex items-center justify-between mt-1">
		{
			error ? (
				<p
					class="text-sm text-destructive"
					style="font-family: var(--font-body);"
					role="alert"
				>
					{error}
				</p>
			) : (
				<span />
			)
		}
		{
			maxlength && (
				<span
					class="text-xs text-[var(--text-tertiary)] ml-auto"
					style="font-family: var(--font-mono);"
					data-counter-for={textareaId}
					data-maxlength={maxlength}
				>
					0 / {maxlength}
				</span>
			)
		}
	</div>
</div>

{
	maxlength && (
		<script define:vars={{ textareaId, maxlength }}>
			const textarea = document.getElementById(textareaId);
			const counter = document.querySelector(
				`[data-counter-for="${textareaId}"]`,
			);
			if (textarea && counter) {
				textarea.addEventListener("input", () => {
					counter.textContent = `${textarea.value.length} / ${maxlength}`;
				});
			}
		</script>
	)
}
