---
/**
 * Thin wrapper that tags a section for the on-load `ds-sectionIn` animation
 * defined in `src/styles/globals.css`. Renders visible HTML with no opacity
 * gate, so SSR, crawlers, print, and full-page screenshots all capture the
 * real content. The animation plays for every visitor on first paint and is
 * disabled automatically under `prefers-reduced-motion: reduce`.
 */
type Props = {
	class?: string;
	tag?: "section" | "div";
	style?: string;
};

const { class: className = "", tag = "section", style } = Astro.props;
const Tag = tag;
---

<Tag class={`ds-section ${className}`.trim()} style={style}>
	<slot />
</Tag>
