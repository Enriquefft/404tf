---
type Props = {
	class?: string;
	tag?: "section" | "div";
};

const { class: className = "", tag = "section" } = Astro.props;
const Tag = tag;
---

<Tag class={`fade-in-section ${className}`} data-fade-in>
	<slot />
</Tag>

<script>
	function initFadeIn() {
		const sections = document.querySelectorAll<HTMLElement>("[data-fade-in]");
		if (sections.length === 0) return;

		const observer = new IntersectionObserver(
			(entries) => {
				for (const entry of entries) {
					if (entry.isIntersecting) {
						entry.target.classList.add("ds-section");
						observer.unobserve(entry.target);
					}
				}
			},
			{ threshold: 0.1, rootMargin: "0px 0px -40px 0px" },
		);

		for (const section of sections) {
			// Start hidden
			section.style.opacity = "0";
			observer.observe(section);
		}
	}

	// Run on initial load
	initFadeIn();
	// Re-run on Astro page transitions (view transitions)
	document.addEventListener("astro:after-swap", initFadeIn);
</script>
