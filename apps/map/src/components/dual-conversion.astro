---
import CorporateCTA from "@/components/corporate-cta.astro";
import FadeInSection from "@/components/fade-in-section.astro";
import SectionLabel from "@/components/ui/section-label.astro";
import type { Locale } from "@/i18n/translations";

type Props = {
	locale: Locale;
	label: string;
	headline: string;
	corporateTitle: string;
	corporateDesc: string;
	corporateSteps: string[];
	startupTitle: string;
	startupDesc: string;
	startupSteps: string[];
	ctaGetOnMap: string;
	startupsHref: string;
};

const {
	locale,
	label,
	headline,
	corporateTitle,
	corporateDesc,
	corporateSteps,
	startupTitle,
	startupDesc,
	startupSteps,
	ctaGetOnMap,
	startupsHref,
} = Astro.props;
---

<FadeInSection class="py-20 sm:py-28" style="background: var(--card);">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="mb-10 text-center">
			<SectionLabel text={label} />
			<h2
				class="mt-3 text-3xl font-bold tracking-tight text-foreground sm:text-4xl"
				style="font-family: var(--font-display);"
			>
				{headline}
			</h2>
		</div>

		<div class="grid gap-6 lg:grid-cols-2">
			<!-- Corporate card (dominant) -->
			<div
				class="flex flex-col gap-6 border p-8"
				style="background: var(--popover); border-color: var(--primary);"
			>
				<div>
					<h3
						class="text-xl font-bold text-foreground sm:text-2xl"
						style="font-family: var(--font-display);"
					>
						{corporateTitle}
					</h3>
					<p
						class="mt-2 text-sm leading-relaxed text-muted-foreground"
						style="font-family: var(--font-body);"
					>
						{corporateDesc}
					</p>
				</div>

				<ol class="flex flex-col gap-4">
					{
						corporateSteps.map((step, idx) => (
							<li class="flex items-start gap-3">
								<span
									class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-xs font-semibold"
									style="background: var(--primary-15); color: var(--primary-light); font-family: var(--font-mono);"
								>
									{idx + 1}
								</span>
								<span
									class="pt-0.5 text-sm text-foreground"
									style="font-family: var(--font-body);"
								>
									{step}
								</span>
							</li>
						))
					}
				</ol>

				<div class="pt-2">
					<CorporateCTA locale={locale} variant="primary" />
				</div>
			</div>

			<!-- Startup card (secondary) -->
			<div
				class="flex flex-col gap-6 border p-8"
				style="background: var(--popover); border-color: var(--border-subtle);"
			>
				<div>
					<h3
						class="text-xl font-bold text-foreground sm:text-2xl"
						style="font-family: var(--font-display);"
					>
						{startupTitle}
					</h3>
					<p
						class="mt-2 text-sm leading-relaxed text-muted-foreground"
						style="font-family: var(--font-body);"
					>
						{startupDesc}
					</p>
				</div>

				<ol class="flex flex-col gap-4">
					{
						startupSteps.map((step, idx) => (
							<li class="flex items-start gap-3">
								<span
									class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-xs font-semibold"
									style="background: var(--primary-8); color: var(--muted-foreground); font-family: var(--font-mono);"
								>
									{idx + 1}
								</span>
								<span
									class="pt-0.5 text-sm text-foreground"
									style="font-family: var(--font-body);"
								>
									{step}
								</span>
							</li>
						))
					}
				</ol>

				<div class="pt-2">
					<a
						href={startupsHref}
						class="inline-flex min-h-11 items-center justify-center gap-2 px-5 py-2.5 font-semibold transition-all duration-150 ease-out"
						style="font-family: var(--font-heading); border-radius: var(--radius-md); color: var(--primary); border: 1px solid var(--primary); background: transparent;"
					>
						{ctaGetOnMap}
						<svg
							width="16"
							height="16"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"
						>
							<path d="M9 5l6 7-6 7" />
						</svg>
					</a>
				</div>
			</div>
		</div>
	</div>
</FadeInSection>
