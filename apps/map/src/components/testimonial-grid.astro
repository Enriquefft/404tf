---
/**
 * Testimonial Grid — 3 quote cards, institutional tone.
 *
 * No avatars (we don't have photos yet). Each card shows a large amber
 * opening quote glyph, the quote body in display-font, and author/role in
 * mono muted. Quotes are passed in as props so translations stay the single
 * source of truth.
 */
import FadeInSection from "@/components/fade-in-section.astro";
import SectionLabel from "@/components/ui/section-label.astro";
import type { Locale } from "@/i18n/translations";

type Testimonial = {
	quote: string;
	author: string;
	role: string;
};

type Props = {
	locale: Locale;
	label: string;
	headline: string;
	testimonials: readonly [Testimonial, Testimonial, Testimonial];
};

const { label, headline, testimonials } = Astro.props;
---

<FadeInSection class="py-20 sm:py-28">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="mb-12 max-w-2xl">
			<SectionLabel text={label} />
			<h2
				class="mt-3 text-3xl font-bold tracking-tight text-foreground sm:text-4xl"
				style="font-family: var(--font-display);"
			>
				{headline}
			</h2>
		</div>

		<div class="grid gap-6 md:grid-cols-3">
			{
				testimonials.map((t) => (
					<figure
						class="flex flex-col gap-6 border p-6 sm:p-7"
						style="background: var(--card); border-color: var(--border-subtle);"
					>
						<span
							aria-hidden="true"
							class="leading-none"
							style="font-family: var(--font-display); font-size: 4rem; color: var(--secondary);"
						>
							&ldquo;
						</span>
						<blockquote class="flex-1">
							<p
								class="text-lg font-medium leading-snug text-foreground"
								style="font-family: var(--font-display);"
							>
								{t.quote}
							</p>
						</blockquote>
						<figcaption class="flex flex-col gap-1 border-t pt-4" style="border-color: var(--border-subtle);">
							<span
								class="text-xs font-semibold uppercase text-foreground"
								style="font-family: var(--font-mono); letter-spacing: 0.12em;"
							>
								{t.author}
							</span>
							<span
								class="text-xs text-muted-foreground"
								style="font-family: var(--font-mono); letter-spacing: 0.06em;"
							>
								{t.role}
							</span>
						</figcaption>
					</figure>
				))
			}
		</div>
	</div>
</FadeInSection>
