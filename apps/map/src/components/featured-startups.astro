---
import FadeInSection from "@/components/fade-in-section.astro";
import SectionLabel from "@/components/ui/section-label.astro";
import StartupCard from "@/components/ui/startup-card.astro";
import { getTranslations, type Locale } from "@/i18n/translations";
import type { StartupRecord } from "@/lib/startup-schema";

type Props = {
	startups: readonly StartupRecord[];
	locale: Locale;
	label: string;
	headline: string;
	linkText: string;
	directoryHref: string;
};

const { startups, locale, label, headline, linkText, directoryHref } = Astro.props;
const t = getTranslations(locale);

/**
 * Six editorially chosen startups spanning different verticals, countries,
 * and maturity levels — the first taste of what the directory is.
 */
const FEATURED_SLUGS = [
	"notco",
	"horus-prosthetics",
	"greenfluidics",
	"satellites-on-fire",
	"tumi-robotics",
	"eywa-bio",
] as const;

const featured = FEATURED_SLUGS.map((slug) => startups.find((s) => s.slug === slug)).filter(
	(s): s is StartupRecord => s !== undefined,
);
---

<FadeInSection class="py-20 sm:py-28">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<!-- Editorial header: kicker (mono amber) → section label → display headline -->
		<div class="mb-10 max-w-3xl">
			<div
				class="mb-3 text-[11px] uppercase"
				style="font-family: var(--font-mono); color: var(--secondary); letter-spacing: 0.14em; font-weight: 600;"
			>
				{t.landing.featuredKicker}
			</div>
			<SectionLabel text={label} />
			<h2
				class="mt-3 text-4xl font-bold tracking-tight text-foreground sm:text-5xl"
				style="font-family: var(--font-display); line-height: 1.05;"
			>
				{headline}
			</h2>
		</div>

		<!-- 3 × 2 grid on desktop, 2-col on md, 1-col on small -->
		<div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
			{
				featured.map((s) => {
					const oneLiner = locale === "en" ? s.one_liner_en : s.one_liner;
					return (
						<StartupCard
							startup={{
								slug: s.slug,
								name: s.name,
								one_liner: oneLiner,
								country: s.country,
								country_es: s.country_es,
								city: s.city,
								verticals: s.verticals,
								maturity_level: s.maturity_level,
								funding_received: s.funding_received,
							}}
							locale={locale}
							href={`/${locale}/startup/${s.slug}`}
						/>
					);
				})
			}
		</div>

		<div class="mt-10 text-center">
			<a
				href={directoryHref}
				class="inline-flex items-center gap-2 text-sm font-medium text-primary transition-colors duration-150 hover:text-foreground"
				style="font-family: var(--font-display);"
			>
				{linkText}
				<svg
					width="16"
					height="16"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
				>
					<path d="M9 5l6 7-6 7"></path>
				</svg>
			</a>
		</div>
	</div>
</FadeInSection>
