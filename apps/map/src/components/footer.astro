---
import type { Locale } from "@/i18n/translations";
import { getTranslations } from "@/i18n/translations";
import { getAlternateLocale, getAlternateLocalePath, getRouteHref } from "@/i18n/utils";

type Props = {
	locale: Locale;
};

const { locale } = Astro.props;
const t = getTranslations(locale);
const altLocale = getAlternateLocale(locale);
const currentPath = Astro.url.pathname;
const altPath = getAlternateLocalePath(currentPath, altLocale);

const navLinks = [
	{ label: t.footer.methodology, href: getRouteHref("about", locale) },
	{ label: t.nav.directory, href: getRouteHref("directory", locale) },
	{ label: t.nav.insights, href: getRouteHref("insights", locale) },
	{ label: t.nav.startups, href: getRouteHref("startups", locale) },
	{ label: t.nav.contact, href: getRouteHref("contact", locale) },
] as const;

// Legal pages live outside ROUTE_MAP because they are static placeholders.
// Slugs are locale-specific but resolve to /{locale}/legal/{slug}.
const legalSlugs = {
	terms: { en: "terms", es: "terminos" },
	privacy: { en: "privacy", es: "privacidad" },
	cookies: { en: "cookies", es: "cookies" },
} as const;

const legalLinks = [
	{ label: t.footer.legalTerms, href: `/${locale}/legal/${legalSlugs.terms[locale]}` },
	{ label: t.footer.legalPrivacy, href: `/${locale}/legal/${legalSlugs.privacy[locale]}` },
	{ label: t.footer.legalCookies, href: `/${locale}/legal/${legalSlugs.cookies[locale]}` },
] as const;

const langLabel = t.common.alternateLanguageName;
const rights = t.footer.rights;
---

<footer class="border-t border-border-subtle bg-card">
	<div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
		<div class="grid gap-8 sm:grid-cols-3">
			<!-- Column 1: Brand + email -->
			<div>
				<p
					class="text-lg font-semibold text-foreground"
					style="font-family: var(--font-display);"
				>
					<span style="color: var(--secondary);">404</span> Mapped
				</p>
				<p
					class="mt-3 max-w-xs text-sm leading-relaxed text-muted-foreground"
					style="font-family: var(--font-body);"
				>
					{t.footer.description}
				</p>
				<a
					href="mailto:enriquefft@404tf.com"
					class="mt-4 inline-block text-sm text-muted-foreground transition-colors duration-150 hover:text-foreground"
					style="font-family: var(--font-mono);"
				>
					enriquefft@<span style="color: var(--secondary);">404</span>tf.com
				</a>
			</div>

			<!-- Column 2: Navigation -->
			<div>
				<p
					class="text-xs font-semibold uppercase tracking-wider text-muted-foreground"
					style="font-family: var(--font-mono);"
				>
					{t.footer.navHeading}
				</p>
				<ul class="mt-3 space-y-2">
					{
						navLinks.map((link) => (
							<li>
								<a
									href={link.href}
									class="text-sm text-muted-foreground transition-colors duration-150 hover:text-foreground"
									style="font-family: var(--font-body);"
								>
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
			</div>

			<!-- Column 3: Legal -->
			<div>
				<p
					class="text-xs font-semibold uppercase tracking-wider text-muted-foreground"
					style="font-family: var(--font-mono);"
				>
					{t.footer.legalHeading}
				</p>
				<ul class="mt-3 space-y-2">
					{
						legalLinks.map((link) => (
							<li>
								<a
									href={link.href}
									class="text-sm text-muted-foreground transition-colors duration-150 hover:text-foreground"
									style="font-family: var(--font-body);"
								>
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</div>

		<!-- Bottom bar -->
		<div
			class="mt-10 flex flex-col items-center justify-between gap-3 border-t border-border-subtle pt-6 sm:flex-row"
		>
			<p
				class="text-xs text-muted-foreground"
				style="font-family: var(--font-mono);"
			>
				&copy; 2026 · <span style="color: var(--secondary);">404</span> Tech Found · {rights}
			</p>
			<a
				href={altPath}
				class="text-xs font-medium text-muted-foreground transition-colors duration-150 hover:text-foreground"
				style="font-family: var(--font-mono);"
			>
				{langLabel}
			</a>
		</div>
	</div>
</footer>
