---
type Props = {
	class?: string;
	size?: number;
};

const { class: className = "", size = 20 } = Astro.props;
---

<!-- Solar: Alt Arrow Down Linear -->
<svg
	xmlns="http://www.w3.org/2000/svg"
	width={size}
	height={size}
	viewBox="0 0 24 24"
	fill="none"
	stroke="currentColor"
	stroke-width="1.5"
	stroke-linecap="round"
	stroke-linejoin="round"
	class={className}
	aria-hidden="true"
>
	<path d="M19 9l-7 6-7-6" />
</svg>
