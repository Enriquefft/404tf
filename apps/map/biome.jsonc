{
	"$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
	"extends": ["../../packages/config/biome.jsonc"],
	"vcs": {
		"enabled": false
	},
	"files": {
		"includes": ["src/**", "scripts/**", "!.claude"],
		"ignoreUnknown": true
	},
	"overrides": [
		{
			"includes": ["**/*.astro"],
			"linter": {
				"rules": {
					"style": {
						"noDefaultExport": "off"
					},
					"correctness": {
						"noUnusedVariables": "off",
						"noUnusedImports": "off"
					}
				}
			}
		},
		{
			"includes": ["scripts/**"],
			"linter": {
				"rules": {
					"correctness": {
						"noUnusedVariables": "off",
						"noUnusedImports": "off"
					}
				}
			}
		}
	]
}
