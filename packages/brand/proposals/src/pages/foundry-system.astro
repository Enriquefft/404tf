---
import "@/styles/global.css"
import { Button } from "@/components/ui/button"
---

<html lang="en" data-theme="foundry">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Foundry Design System — 404 Tech Found</title>
  <style>
    /* ── Entrance choreography ──────────────────────────────── */
    @keyframes emerge {
      from { opacity: 0; transform: translateY(24px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes expand-right {
      from { transform: scaleX(0); }
      to { transform: scaleX(1); }
    }
    @keyframes drift {
      0%, 100% { transform: translateY(0) rotate(0deg); }
      40% { transform: translateY(-8px) rotate(0.3deg); }
      70% { transform: translateY(4px) rotate(-0.15deg); }
    }
    @keyframes strike-draw {
      from { width: 0; }
      to { width: 100%; }
    }
    @keyframes fade-struck {
      from { opacity: 1; }
      to { opacity: 0.15; }
    }

    .emerge {
      opacity: 0;
      animation: emerge 700ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
      animation-delay: var(--d, 0ms);
    }
    .on-scroll {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 600ms cubic-bezier(0.16, 1, 0.3, 1),
                  transform 600ms cubic-bezier(0.16, 1, 0.3, 1);
      transition-delay: var(--d, 0ms);
    }
    .on-scroll.revealed {
      opacity: 1;
      transform: translateY(0);
    }

    /* ── Atmospheric layers ─────────────────────────────────── */
    .atmosphere {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: -1;
      background:
        radial-gradient(ellipse 80% 45% at 20% 110%, oklch(0.14 0.08 305 / 35%), transparent 65%),
        radial-gradient(ellipse 40% 35% at 85% 10%, oklch(0.12 0.06 310 / 20%), transparent 55%);
    }

    .grain {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 9998;
      opacity: 0.025;
      mix-blend-mode: overlay;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      background-size: 256px 256px;
    }

    /* ── Section label ──────────────────────────────────────── */
    .label {
      font-family: var(--font-body);
      font-size: 0.6875rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: oklch(0.55 0.22 305 / 65%);
    }

    /* ── Manifesto lines ────────────────────────────────────── */
    .manifesto-line {
      font-family: var(--font-display);
      font-size: clamp(1.6rem, 4.5vw, 3.2rem);
      font-weight: 700;
      line-height: 1.1;
      text-transform: uppercase;
      letter-spacing: 0;
      color: oklch(0.92 0.008 55 / 85%);
      transition: text-shadow 300ms cubic-bezier(0.25, 1, 0.5, 1);
    }
    .manifesto-line:hover {
      text-shadow: 0 0 30px oklch(0.44 0.24 305 / 25%), 0 0 60px oklch(0.44 0.24 305 / 10%);
    }

    /* ── Background watermark ───────────────────────────────── */
    .watermark {
      position: absolute;
      font-family: var(--font-display);
      font-size: clamp(15rem, 40vw, 35rem);
      font-weight: 900;
      line-height: 0.8;
      text-transform: uppercase;
      color: oklch(0.44 0.24 305 / 3%);
      pointer-events: none;
      user-select: none;
    }

    /* ── Section divider ────────────────────────────────────── */
    .divider-gradient {
      height: 2px;
      background: linear-gradient(to right, oklch(0.44 0.24 305 / 60%), oklch(0.72 0.18 55 / 60%), transparent);
    }

    /* ── Color band interaction ─────────────────────────────── */
    .color-band {
      transition: padding-left 250ms cubic-bezier(0.25, 1, 0.5, 1);
    }
    .color-band:hover {
      padding-left: calc(var(--pad) + 12px);
    }

    /* ── House row interaction ──────────────────────────────── */
    .house-row {
      transition: background-color 200ms cubic-bezier(0.25, 1, 0.5, 1),
                  padding-left 200ms cubic-bezier(0.25, 1, 0.5, 1);
    }
    .house-row:hover {
      padding-left: calc(var(--pad) + 6px);
    }

    /* ── Design system spec utilities ───────────────────────── */
    .spec-row {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      padding: 0.75rem 0;
      border-bottom: 1px solid oklch(1 0.008 310 / 5%);
    }
    .spec-label {
      font-family: var(--font-body);
      font-size: 0.75rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: oklch(0.52 0.018 315);
    }
    .spec-value {
      font-family: var(--font-code);
      font-size: 0.75rem;
      color: oklch(0.92 0.008 55 / 60%);
    }
    .swatch {
      width: 3rem;
      height: 3rem;
      border: 2px solid oklch(1 0.008 310 / 8%);
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    .section-number {
      font-family: var(--font-display);
      font-size: clamp(6rem, 15vw, 10rem);
      font-weight: 900;
      line-height: 0.8;
      color: oklch(0.44 0.24 305 / 5%);
      position: absolute;
      right: -2%;
      top: -10%;
      pointer-events: none;
      user-select: none;
    }

    /* ── Reduced motion ─────────────────────────────────────── */
    @media (prefers-reduced-motion: reduce) {
      .emerge { animation: none; opacity: 1; transform: none; }
      .on-scroll { transition: none; opacity: 1; transform: none; }
      .manifesto-line { transition: none; }
    }
  </style>
</head>

<body class="bg-background text-foreground overflow-x-hidden">
  <div class="atmosphere"></div>
  <div class="grain"></div>

  <!-- Navigation -->
  <nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 md:px-12 lg:px-20 py-5">
    <a
      href="/"
      style="font-family: var(--font-body)"
      class="text-[0.625rem] uppercase tracking-[0.2em] text-muted-foreground/80 hover:text-secondary transition-colors duration-200"
    >
      All proposals
    </a>
    <a
      href="/foundry"
      style="font-family: var(--font-body)"
      class="text-[0.625rem] uppercase tracking-[0.2em] text-muted-foreground/80 hover:text-primary transition-colors duration-200"
    >
      Foundry showcase
    </a>
  </nav>

  <!-- ═══ SECTION 0: SYSTEM HEADER ═════════════════════════════════ -->
  <section class="relative px-6 md:px-12 lg:px-20 pt-32 md:pt-40 pb-20 md:pb-28">
    <div class="relative z-10 max-w-4xl">
      <p class="emerge label mb-8" style="--d: 200ms">Proposal T · Design System Reference</p>

      <h1>
        <span
          class="emerge block uppercase tracking-[-0.02em]"
          style="--d: 400ms; font-family: var(--font-display); font-size: clamp(4rem, 12vw, 10rem); font-weight: 900; line-height: 0.85; color: oklch(0.44 0.24 305);"
        >
          Foundry
        </span>
        <span
          class="emerge block uppercase tracking-[0.12em] mt-2"
          style="--d: 600ms; font-family: var(--font-display); font-size: clamp(1.2rem, 3.5vw, 2.8rem); font-weight: 700; line-height: 1; color: oklch(0.72 0.18 55);"
        >
          Design System
        </span>
      </h1>

      <p
        class="emerge text-[clamp(0.95rem,1.5vw,1.1rem)] text-muted-foreground max-w-lg mt-10 leading-[1.75]"
        style="--d: 800ms"
      >
        The complete visual specification for 404 Tech Found's Foundry brand direction.
      </p>

      <div class="emerge flex items-center gap-4 mt-8" style="--d: 1000ms">
        <div class="flex items-center gap-3">
          <div class="swatch" style="background: oklch(0.44 0.24 305);">
            <span class="text-[0.5rem] font-semibold uppercase tracking-widest" style="color: oklch(0.95 0.008 310)">P</span>
          </div>
          <div class="flex flex-col">
            <span class="text-[0.625rem] font-medium text-foreground/70 uppercase tracking-wider" style="font-family: var(--font-body)">Primary</span>
            <span class="text-[0.625rem] text-muted-foreground/60" style="font-family: var(--font-code)">oklch(0.44 0.24 305)</span>
          </div>
        </div>
        <div class="w-8 h-[2px] bg-gradient-to-r from-primary/40 to-secondary/40"></div>
        <div class="flex items-center gap-3">
          <div class="swatch" style="background: oklch(0.72 0.18 55);">
            <span class="text-[0.5rem] font-semibold uppercase tracking-widest" style="color: oklch(0.07 0.015 320)">S</span>
          </div>
          <div class="flex flex-col">
            <span class="text-[0.625rem] font-medium text-foreground/70 uppercase tracking-wider" style="font-family: var(--font-body)">Secondary</span>
            <span class="text-[0.625rem] text-muted-foreground/60" style="font-family: var(--font-code)">oklch(0.72 0.18 55)</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Expanding rule -->
    <div class="absolute bottom-0 left-0 h-[2px] w-[50%] bg-gradient-to-r from-primary/50 via-secondary/30 to-transparent" style="transform-origin: left; transform: scaleX(0); animation: expand-right 900ms cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: 1.4s;"></div>
  </section>

  <!-- Section divider -->
  <div class="divider-gradient mx-6 md:mx-12 lg:mx-20"></div>

  <!-- ═══ SECTION 1: DESIGN PRINCIPLES ═════════════════════════════ -->
  <section class="relative px-6 md:px-12 lg:px-20 py-24 md:py-36">
    <span class="section-number">01</span>

    <div class="relative z-10">
      <p class="on-scroll label mb-20">Design Principles</p>

      <!-- Principle 01 -->
      <div class="on-scroll border-t-2 border-border py-10 md:py-14 flex flex-col md:flex-row md:items-baseline gap-4 md:gap-16">
        <div class="flex items-baseline gap-6 md:w-[28rem] shrink-0">
          <span style="font-family: var(--font-code); font-size: 0.75rem; color: oklch(0.72 0.18 55 / 60%);">01</span>
          <h3 style="font-family: var(--font-display); font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-weight: 700; text-transform: uppercase; letter-spacing: 0.02em; line-height: 1.1;">
            Earned Attention
          </h3>
        </div>
        <p class="text-[0.9375rem] text-muted-foreground leading-[1.75] max-w-md">
          Every element justifies its existence. No decoration without purpose. If it doesn't communicate, clarify, or compel — it doesn't belong.
        </p>
      </div>

      <!-- Principle 02 -->
      <div class="on-scroll border-t-2 border-border py-10 md:py-14 flex flex-col md:flex-row md:items-baseline gap-4 md:gap-16" style="--d: 60ms">
        <div class="flex items-baseline gap-6 md:w-[28rem] shrink-0">
          <span style="font-family: var(--font-code); font-size: 0.75rem; color: oklch(0.72 0.18 55 / 60%);">02</span>
          <h3 style="font-family: var(--font-display); font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-weight: 700; text-transform: uppercase; letter-spacing: 0.02em; line-height: 1.1;">
            Purple World, Amber Artifact
          </h3>
        </div>
        <p class="text-[0.9375rem] text-muted-foreground leading-[1.75] max-w-md">
          Purple is the environment, the commitment, the brand. Amber is the discovery, the action, the thing found within. This duality drives every color decision.
        </p>
      </div>

      <!-- Principle 03 -->
      <div class="on-scroll border-t-2 border-border py-10 md:py-14 flex flex-col md:flex-row md:items-baseline gap-4 md:gap-16" style="--d: 120ms">
        <div class="flex items-baseline gap-6 md:w-[28rem] shrink-0">
          <span style="font-family: var(--font-code); font-size: 0.75rem; color: oklch(0.72 0.18 55 / 60%);">03</span>
          <h3 style="font-family: var(--font-display); font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-weight: 700; text-transform: uppercase; letter-spacing: 0.02em; line-height: 1.1;">
            Brutalist Clarity
          </h3>
        </div>
        <p class="text-[0.9375rem] text-muted-foreground leading-[1.75] max-w-md">
          Zero radius. 2px borders. No shadows. Depth through color saturation, not visual tricks. Every surface has a clear edge.
        </p>
      </div>

      <!-- Principle 04 -->
      <div class="on-scroll border-t-2 border-border py-10 md:py-14 flex flex-col md:flex-row md:items-baseline gap-4 md:gap-16" style="--d: 180ms">
        <div class="flex items-baseline gap-6 md:w-[28rem] shrink-0">
          <span style="font-family: var(--font-code); font-size: 0.75rem; color: oklch(0.72 0.18 55 / 60%);">04</span>
          <h3 style="font-family: var(--font-display); font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-weight: 700; text-transform: uppercase; letter-spacing: 0.02em; line-height: 1.1;">
            Industrial Typography
          </h3>
        </div>
        <p class="text-[0.9375rem] text-muted-foreground leading-[1.75] max-w-md">
          Big Shoulders Display commands attention. Barlow communicates clearly. Together they feel built, not designed — forged from function.
        </p>
      </div>

      <!-- Principle 05 -->
      <div class="on-scroll border-t-2 border-border py-10 md:py-14 border-b-2 flex flex-col md:flex-row md:items-baseline gap-4 md:gap-16" style="--d: 240ms">
        <div class="flex items-baseline gap-6 md:w-[28rem] shrink-0">
          <span style="font-family: var(--font-code); font-size: 0.75rem; color: oklch(0.72 0.18 55 / 60%);">05</span>
          <h3 style="font-family: var(--font-display); font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-weight: 700; text-transform: uppercase; letter-spacing: 0.02em; line-height: 1.1;">
            Tardi Resilience
          </h3>
        </div>
        <p class="text-[0.9375rem] text-muted-foreground leading-[1.75] max-w-md">
          The brand feels indestructible, adaptive, alive — like its mascot. Motion is earned, not decorative. Every animation has intent.
        </p>
      </div>
    </div>
  </section>

  <!-- Section divider -->
  <div class="divider-gradient mx-6 md:mx-12 lg:mx-20"></div>

  <!-- ═══ SECTION 2: COLOR SYSTEM ═══════════════════════════════════ -->
  <section class="relative px-6 md:px-12 lg:px-20 py-24 md:py-36">
    <span class="section-number">02</span>

    <div class="relative z-10">
      <p class="on-scroll label mb-6">Color System</p>
      <p class="on-scroll text-sm text-muted-foreground max-w-lg mb-20" style="--d: 60ms">
        Deep violet substrate. Foundry purple as the world. Forge amber as the artifact. Neither generic, neither ordinary. Every color in OKLCH for perceptual uniformity.
      </p>

      <!-- ── 2a. Core Palette ─────────────────────────────────── -->
      <div class="on-scroll mb-24" style="--d: 80ms">
        <p class="text-[0.6875rem] text-muted-foreground/70 uppercase tracking-wider mb-8" style="font-family: var(--font-body)">2a · Core Palette</p>

        <div class="space-y-[2px]">
          <!-- Background -->
          <div class="color-band h-14 md:h-16 flex items-center justify-between px-5 md:px-8 border-2 border-border" style="background: oklch(0.07 0.015 320); --pad: 1.25rem">
            <div class="flex items-center gap-4">
              <span class="text-[0.6875rem] font-medium text-foreground/70 uppercase tracking-wider" style="font-family: var(--font-body)">Background</span>
              <span class="hidden sm:inline text-[0.6rem] text-muted-foreground/40 uppercase tracking-wider" style="font-family: var(--font-body)">Page base, body</span>
            </div>
            <div class="flex items-center gap-4">
              <span class="hidden md:inline text-[0.6875rem] text-muted-foreground/60" style="font-family: var(--font-code)">oklch(0.07 0.015 320)</span>
              <span class="text-[0.6875rem] text-muted-foreground/40" style="font-family: var(--font-code)">#0E0A10</span>
            </div>
          </div>

          <!-- Foreground -->
          <div class="color-band h-14 md:h-16 flex items-center justify-between px-5 md:px-8" style="background: oklch(0.92 0.008 55); --pad: 1.25rem">
            <div class="flex items-center gap-4">
              <span class="text-[0.6875rem] font-medium uppercase tracking-wider" style="font-family: var(--font-body); color: oklch(0.07 0.015 320)">Foreground</span>
              <span class="hidden sm:inline text-[0.6rem] uppercase tracking-wider" style="font-family: var(--font-body); color: oklch(0.07 0.015 320 / 50%)">Primary text</span>
            </div>
            <div class="flex items-center gap-4">
              <span class="hidden md:inline text-[0.6875rem]" style="font-family: var(--font-code); color: oklch(0.07 0.015 320 / 60%)">oklch(0.92 0.008 55)</span>
              <span class="text-[0.6875rem]" style="font-family: var(--font-code); color: oklch(0.07 0.015 320 / 40%)">#EDE8E0</span>
            </div>
          </div>

          <!-- Card -->
          <div class="color-band h-14 md:h-16 flex items-center justify-between px-5 md:px-8" style="background: oklch(0.11 0.018 315); --pad: 1.25rem">
            <div class="flex items-center gap-4">
              <span class="text-[0.6875rem] font-medium text-foreground/70 uppercase tracking-wider" style="font-family: var(--font-body)">Card / Surface</span>
              <span class="hidden sm:inline text-[0.6rem] text-muted-foreground/40 uppercase tracking-wider" style="font-family: var(--font-body)">Elevated panels</span>
            </div>
            <div class="flex items-center gap-4">
              <span class="hidden md:inline text-[0.6875rem] text-muted-foreground/60" style="font-family: var(--font-code)">oklch(0.11 0.018 315)</span>
              <span class="text-[0.6875rem] text-muted-foreground/40" style="font-family: var(--font-code)">#1A1320</span>
            </div>
          </div>

          <!-- Primary -->
          <div class="color-band h-16 md:h-20 flex items-center justify-between px-5 md:px-8" style="background: oklch(0.44 0.24 305); --pad: 1.25rem">
            <div class="flex items-center gap-4">
              <span class="text-xs font-semibold uppercase tracking-wider" style="font-family: var(--font-body); color: oklch(0.95 0.008 310)">Primary — Foundry Purple</span>
              <span class="hidden sm:inline text-[0.6rem] uppercase tracking-wider" style="font-family: var(--font-body); color: oklch(0.95 0.008 310 / 60%)">CTAs, focus, brand</span>
            </div>
            <div class="flex items-center gap-4">
              <span class="hidden md:inline text-[0.6875rem]" style="font-family: var(--font-code); color: oklch(0.95 0.008 310 / 70%)">oklch(0.44 0.24 305)</span>
              <span class="text-[0.6875rem]" style="font-family: var(--font-code); color: oklch(0.95 0.008 310 / 50%)">#7B2080</span>
            </div>
          </div>

          <!-- Primary Bright -->
          <div class="color-band h-14 md:h-16 flex items-center justify-between px-5 md:px-8" style="background: oklch(0.55 0.22 305); --pad: 1.25rem">
            <div class="flex items-center gap-4">
              <span class="text-[0.6875rem] font-medium uppercase tracking-wider" style="font-family: var(--font-body); color: oklch(0.95 0.008 310)">Primary Bright</span>
              <span class="hidden sm:inline text-[0.6rem] uppercase tracking-wider" style="font-family: var(--font-body); color: oklch(0.95 0.008 310 / 50%)">Hover state, focus rings</span>
            </div>
            <div class="flex items-center gap-4">
              <span class="hidden md:inline text-[0.6875rem]" style="font-family: var(--font-code); color: oklch(0.95 0.008 310 / 70%)">oklch(0.55 0.22 305)</span>
              <span class="text-[0.6875rem]" style="font-family: var(--font-code); color: oklch(0.95 0.008 310 / 50%)">#A03BA5</span>
            </div>
          </div>

          <!-- Primary Deep -->
          <div class="color-band h-14 md:h-16 flex items-center justify-between px-5 md:px-8" style="background: oklch(0.33 0.20 305); --pad: 1.25rem">
            <div class="flex items-center gap-4">
              <span class="text-[0.6875rem] font-medium uppercase tracking-wider" style="font-family: var(--font-body); color: oklch(0.95 0.008 310)">Primary Deep</span>
              <span class="hidden sm:inline text-[0.6rem] uppercase tracking-wider" style="font-family: var(--font-body); color: oklch(0.95 0.008 310 / 50%)">Pressed state, depth</span>
            </div>
            <div class="flex items-center gap-4">
              <span class="hidden md:inline text-[0.6875rem]" style="font-family: var(--font-code); color: oklch(0.95 0.008 310 / 70%)">oklch(0.33 0.20 305)</span>
              <span class="text-[0.6875rem]" style="font-family: var(--font-code); color: oklch(0.95 0.008 310 / 50%)">#581060</span>
            </div>
          </div>

          <!-- Secondary -->
          <div class="color-band h-16 md:h-20 flex items-center justify-between px-5 md:px-8" style="background: oklch(0.72 0.18 55); --pad: 1.25rem">
            <div class="flex items-center gap-4">
              <span class="text-xs font-semibold uppercase tracking-wider" style="font-family: var(--font-body); color: oklch(0.07 0.015 320)">Secondary — Forge Amber</span>
              <span class="hidden sm:inline text-[0.6rem] uppercase tracking-wider" style="font-family: var(--font-body); color: oklch(0.07 0.015 320 / 50%)">Tags, 404, discovery</span>
            </div>
            <div class="flex items-center gap-4">
              <span class="hidden md:inline text-[0.6875rem]" style="font-family: var(--font-code); color: oklch(0.07 0.015 320 / 60%)">oklch(0.72 0.18 55)</span>
              <span class="text-[0.6875rem]" style="font-family: var(--font-code); color: oklch(0.07 0.015 320 / 40%)">#D49420</span>
            </div>
          </div>

          <!-- Accent -->
          <div class="color-band h-14 md:h-16 flex items-center justify-between px-5 md:px-8" style="background: oklch(0.16 0.030 310); --pad: 1.25rem">
            <div class="flex items-center gap-4">
              <span class="text-[0.6875rem] font-medium text-foreground/70 uppercase tracking-wider" style="font-family: var(--font-body)">Accent</span>
              <span class="hidden sm:inline text-[0.6rem] text-muted-foreground/40 uppercase tracking-wider" style="font-family: var(--font-body)">Purple-shifted surface</span>
