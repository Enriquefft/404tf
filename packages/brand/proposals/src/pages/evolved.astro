---
import "@/styles/global.css"
import { Button } from "@/components/ui/button"
---

<html lang="en" data-theme="evolved">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>404 Tech Found — Evolved</title>
  <style>
    /* ── Entrance choreography ──────────────────────────────── */
    @keyframes emerge {
      from { opacity: 0; transform: translateY(28px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes draw-down {
      from { transform: scaleY(0); }
      to { transform: scaleY(1); }
    }
    @keyframes drift {
      0%, 100% { transform: translateY(0) rotate(0deg); }
      40% { transform: translateY(-10px) rotate(0.4deg); }
      70% { transform: translateY(5px) rotate(-0.2deg); }
    }

    .emerge {
      opacity: 0;
      animation: emerge 750ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
      animation-delay: var(--d, 0ms);
    }
    .on-scroll {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 650ms cubic-bezier(0.16, 1, 0.3, 1),
                  transform 650ms cubic-bezier(0.16, 1, 0.3, 1);
      transition-delay: var(--d, 0ms);
    }
    .on-scroll.revealed {
      opacity: 1;
      transform: translateY(0);
    }

    /* ── Atmospheric layers ─────────────────────────────────── */

    /* Purple emanates from upper-right — Tardi is the source */
    .atmosphere {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: -1;
      background:
        radial-gradient(ellipse 50% 60% at 75% 15%, oklch(0.18 0.08 305 / 35%), transparent 70%),
        radial-gradient(ellipse 40% 50% at 10% 80%, oklch(0.12 0.04 340 / 20%), transparent 60%);
    }

    /* Film grain — adds tactile warmth, kills the "flat digital" feel */
    .grain {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 9998;
      opacity: 0.02;
      mix-blend-mode: overlay;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      background-size: 256px 256px;
    }

    /* ── Tardi drift ────────────────────────────────────────── */
    .tardi-drift {
      animation: drift 12s cubic-bezier(0.45, 0, 0.55, 1) infinite;
    }

    /* ── Scroll line draws on load ──────────────────────────── */
    .scroll-line {
      transform-origin: top;
      transform: scaleY(0);
      animation: draw-down 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      animation-delay: 1.4s;
    }

    /* ── Color band interaction ─────────────────────────────── */
    .color-band {
      transition: padding-left 250ms cubic-bezier(0.25, 1, 0.5, 1);
    }
    .color-band:hover {
      padding-left: calc(var(--pad) + 12px);
    }

    /* ── House row interaction ──────────────────────────────── */
    .house-row {
      transition: background-color 200ms cubic-bezier(0.25, 1, 0.5, 1),
                  padding-left 200ms cubic-bezier(0.25, 1, 0.5, 1);
    }
    .house-row:hover {
      padding-left: calc(var(--pad) + 6px);
    }

    /* ── Section label style ────────────────────────────────── */
    .label {
      font-size: 0.6875rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: oklch(0.55 0.25 305 / 50%);
    }

    /* ── The 404 watermark ──────────────────────────────────── */
    .watermark {
      position: absolute;
      font-size: clamp(15rem, 40vw, 35rem);
      font-weight: 900;
      line-height: 0.8;
      color: oklch(0.55 0.25 305 / 3%);
      pointer-events: none;
      user-select: none;
    }

    /* ── Reduced motion ─────────────────────────────────────── */
    @media (prefers-reduced-motion: reduce) {
      .emerge { animation: none; opacity: 1; transform: none; }
      .on-scroll { transition: none; opacity: 1; transform: none; }
      .tardi-drift { animation: none; }
      .scroll-line { animation: none; transform: scaleY(1); }
    }
  </style>
</head>

<body class="bg-background text-foreground overflow-x-hidden">
  <div class="atmosphere"></div>
  <div class="grain"></div>

  <!-- Back to all proposals -->
  <a
    href="/"
    style="font-family: system-ui"
    class="fixed top-5 left-6 z-50 text-[0.625rem] uppercase tracking-[0.2em] text-muted-foreground/60 hover:text-primary transition-colors duration-200"
  >
    All proposals
  </a>

  <!-- ═══ HERO ═══════════════════════════════════════════════════ -->
  <section class="min-h-svh relative flex items-end px-6 md:px-16 lg:px-24 pb-24 md:pb-32">
    <!-- Tardi — atmospheric hero presence, upper-right. The SOURCE of purple light. -->
    <div class="tardi-drift absolute right-[-10%] top-[5%] md:right-[0%] md:top-[2%] w-[60vw] md:w-[38vw] max-w-[520px] pointer-events-none select-none">
      <img
        src="/tardi.png"
        alt=""
        class="w-full h-auto"
        style="opacity: 0.18; filter: brightness(0.7) saturate(0.6) hue-rotate(-15deg);"
      />
    </div>

    <div class="relative z-10 max-w-5xl">
      <p class="label mb-8 emerge" style="--d: 300ms">Proposal N · Evolved</p>

      <h1>
        <span
          class="emerge block text-[clamp(7rem,18vw,16rem)] font-black leading-[0.78] tracking-[-0.03em] text-primary"
          style="--d: 500ms"
        >
          404
        </span>
        <span
          class="emerge block text-[clamp(0.9rem,2.8vw,2.2rem)] font-medium tracking-[0.3em] text-foreground/50 mt-3"
          style="--d: 650ms"
        >
          TECH FOUND
        </span>
      </h1>

      <p
        class="emerge text-[clamp(1rem,1.8vw,1.25rem)] text-muted-foreground max-w-sm mt-12 leading-[1.7]"
        style="--d: 800ms"
      >
        Engineering the next anomaly.<br />
        Where LATAM's breakthroughs go from lab to launch.
      </p>

      <div class="emerge flex gap-4 mt-12 flex-wrap" style="--d: 950ms">
        <Button client:load size="lg" className="text-sm px-8 tracking-wide">
          Join the Movement
        </Button>
        <Button client:load variant="outline" size="lg" className="text-sm px-8 tracking-wide">
          Explore
        </Button>
      </div>
    </div>

    <!-- Scroll line -->
    <div class="scroll-line absolute bottom-0 left-1/2 -translate-x-1/2 h-24 w-px bg-gradient-to-b from-transparent via-primary/30 to-transparent"></div>
  </section>

  <!-- ═══ IDENTITY STRIP ═══════════════════════════════════════── -->
  <div class="on-scroll border-y border-border">
    <div class="flex items-center justify-between gap-x-8 px-6 md:px-16 lg:px-24 py-4 overflow-x-auto text-[0.625rem] uppercase tracking-[0.18em] text-muted-foreground/60">
      <span class="shrink-0 font-semibold text-foreground/40">Evolved</span>
      <span class="shrink-0 hidden sm:block">Gabarito</span>
      <span class="shrink-0 hidden sm:block">Work Sans</span>
      <span class="shrink-0 hidden md:block">JetBrains Mono</span>
      <span class="shrink-0 flex items-center gap-2">
        <span class="w-2 h-2 rounded-sm bg-primary"></span>
        #8B3AE8
      </span>
    </div>
  </div>

  <!-- ═══ THE VOID — Brand Narrative ═══════════════════════════── -->
  <section class="relative px-6 md:px-16 lg:px-24 pt-32 md:pt-48 pb-24 md:pb-36">
    <!-- 404 watermark -->
    <span class="watermark -right-[5%] top-[10%]">404</span>

    <div class="relative z-10 max-w-2xl">
      <p class="on-scroll label mb-12">The Narrative</p>

      <p class="on-scroll text-[clamp(1.15rem,2vw,1.45rem)] leading-[1.75] text-foreground/70">
        In a world of <strong class="text-primary font-semibold">404 errors</strong>,
        most people see a dead end. We see a signal — a glitch in the matrix
        that reveals something <strong class="text-foreground font-semibold">extraordinary</strong>
        hiding underneath.
      </p>

      <p class="on-scroll text-[clamp(1.15rem,2vw,1.45rem)] leading-[1.75] text-foreground/70 mt-8" style="--d: 80ms">
        Breakthrough science. Maverick founders. Technologies that refuse
        to fit existing categories. We turn them into ventures — right where
        the talent is.
      </p>

      <p class="on-scroll text-[clamp(1.15rem,2vw,1.45rem)] leading-[1.75] text-foreground/70 mt-8" style="--d: 160ms">
        Like the <strong class="text-primary font-semibold">tardigrade</strong> —
        the most resilient creature on Earth — our startups don't just survive.
        They thrive in conditions nothing else can.
      </p>
    </div>
  </section>

  <!-- ═══ COLOR UNIVERSE ═══════════════════════════════════════── -->
  <section class="on-scroll py-20 md:py-28">
    <div class="px-6 md:px-16 lg:px-24 mb-12">
      <p class="label">Color Universe</p>
      <p class="text-sm text-muted-foreground mt-3 max-w-md">
        Purple is atmospheric, not structural. The base is warm near-black.
        Purple enters as light. House colors own the spectrum.
      </p>
    </div>

    <div class="space-y-[1px]">
      <div class="color-band h-14 md:h-16 bg-background flex items-center justify-between px-6 md:px-16 lg:px-24 border-y border-border" style="--pad: 1.5rem">
        <span class="text-[0.6875rem] font-medium text-foreground/50 uppercase tracking-wider">Base</span>
        <span class="text-[0.6875rem] font-mono text-muted-foreground/60">oklch(0.08 0.012 340)</span>
      </div>
      <div class="color-band h-14 md:h-16 bg-card flex items-center justify-between px-6 md:px-16 lg:px-24" style="--pad: 1.5rem">
        <span class="text-[0.6875rem] font-medium text-foreground/50 uppercase tracking-wider">Surface</span>
        <span class="text-[0.6875rem] font-mono text-muted-foreground/60">oklch(0.12 0.015 340)</span>
      </div>
      <div class="color-band h-16 md:h-20 bg-primary flex items-center justify-between px-6 md:px-16 lg:px-24" style="--pad: 1.5rem">
        <span class="text-xs font-semibold text-primary-foreground uppercase tracking-wider">Primary — Purple Atmosphere</span>
        <span class="text-[0.6875rem] font-mono text-primary-foreground/70">#8B3AE8</span>
      </div>
      <div class="color-band h-14 md:h-16 flex items-center justify-between px-6 md:px-16 lg:px-24" style="background: var(--house-ai); --pad: 1.5rem">
        <span class="text-[0.6875rem] font-semibold uppercase tracking-wider" style="color: oklch(0.12 0.02 340)">House AI</span>
        <span class="text-[0.6875rem] font-mono" style="color: oklch(0.18 0.02 340)">#FF3CAC</span>
      </div>
      <div class="color-band h-14 md:h-16 flex items-center justify-between px-6 md:px-16 lg:px-24" style="background: var(--house-biotech); --pad: 1.5rem">
        <span class="text-[0.6875rem] font-semibold uppercase tracking-wider" style="color: oklch(0.12 0.02 155)">House Biotech</span>
        <span class="text-[0.6875rem] font-mono" style="color: oklch(0.18 0.02 155)">#00E676</span>
      </div>
      <div class="color-band h-14 md:h-16 flex items-center justify-between px-6 md:px-16 lg:px-24" style="background: var(--house-hardware); --pad: 1.5rem">
        <span class="text-[0.6875rem] font-semibold uppercase tracking-wider" style="color: oklch(0.15 0.02 90)">House Hardware</span>
        <span class="text-[0.6875rem] font-mono" style="color: oklch(0.22 0.02 90)">#FFD600</span>
      </div>
    </div>
  </section>

  <!-- ═══ TYPOGRAPHY ═══════════════════════════════════════════── -->
  <section class="px-6 md:px-16 lg:px-24 pt-24 md:pt-36 pb-20 md:pb-28">
    <p class="on-scroll label mb-20">Typography</p>

    <!-- Display specimen -->
    <div class="on-scroll mb-24">
      <p class="text-[0.6875rem] text-muted-foreground/50 mb-5 uppercase tracking-wider">Display · Gabarito</p>
      <h2 class="text-[clamp(2.8rem,8vw,7rem)] font-bold leading-[0.95] tracking-[-0.02em]">
        Breaking the Laws<br class="hidden md:block" /> of Deep Tech
      </h2>
    </div>

    <!-- Secondary display -->
    <div class="on-scroll mb-24" style="--d: 80ms">
      <h3 class="text-[clamp(1.5rem,4vw,3.5rem)] font-semibold text-foreground/70 leading-[1.1] max-w-3xl">
        Building LATAM's Future,<br />One Anomaly at a Time
      </h3>
    </div>

    <!-- Body specimen -->
    <div class="on-scroll max-w-[62ch] mb-20" style="--d: 120ms">
      <p class="text-[0.6875rem] text-muted-foreground/50 mb-5 uppercase tracking-wider">Body · Work Sans</p>
      <p class="text-[1.0625rem] leading-[1.75] text-foreground/80">
        404 Tech Found is LATAM's maverick deep-tech pre-incubator, built by
        founders for founders. We turn breakthrough science into venture-grade
        companies — catalysing the next generation of biotech, AI, and hardware
        startups right where the talent is.
      </p>
      <p class="text-[0.9375rem] text-muted-foreground leading-[1.75] mt-5">
        Secondary text for captions, metadata, and supporting content that
        doesn't compete with primary messaging but remains comfortably readable.
      </p>
    </div>

    <!-- Code specimen -->
    <div class="on-scroll max-w-2xl" style="--d: 160ms">
      <p class="text-[0.6875rem] text-muted-foreground/50 mb-5 uppercase tracking-wider">Code · JetBrains Mono</p>
      <pre class="bg-card border border-border rounded-lg p-6 text-sm leading-[1.75] overflow-x-auto"><code class="text-foreground"><span class="text-primary">const</span> deeptech = <span class="text-primary">await</span> discover({"{"}<br />  region: <span class="text-house-biotech">"LATAM"</span>,<br />  verticals: [<span class="text-house-ai">"AI"</span>, <span class="text-house-biotech">"Biotech"</span>, <span class="text-house-hardware">"Hardware"</span>],<br />  status: <span class="text-primary">404</span>, <span class="text-muted-foreground">// not found — until now</span><br />{"}"});</code></pre>
    </div>
  </section>

  <!-- ═══ PROGRAMME HOUSES ═════════════════════════════════════── -->
  <section class="py-20 md:py-28">
    <div class="px-6 md:px-16 lg:px-24 mb-12">
      <p class="on-scroll label">Programme Houses</p>
      <p class="on-scroll text-sm text-muted-foreground mt-3">Three verticals. Three identities. One mission.</p>
    </div>

    <div class="on-scroll border-y border-border divide-y divide-border">
      <div class="house-row flex items-center gap-5 md:gap-8 px-6 md:px-16 lg:px-24 py-5 md:py-6 hover:bg-house-ai/[0.04] cursor-default" style="--pad: 1.5rem">
        <svg class="w-[18px] h-[18px] text-house-ai shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" />
        </svg>
        <h3 class="text-lg font-bold text-house-ai">AI</h3>
        <span class="flex-1 hidden sm:block h-px bg-border"></span>
        <p class="text-sm text-muted-foreground italic hidden sm:block shrink-0">"Code that thinks."</p>
      </div>

      <div class="house-row flex items-center gap-5 md:gap-8 px-6 md:px-16 lg:px-24 py-5 md:py-6 hover:bg-house-biotech/[0.04] cursor-default" style="--pad: 1.5rem">
        <svg class="w-[18px] h-[18px] text-house-biotech shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
        </svg>
        <h3 class="text-lg font-bold text-house-biotech">Biotech</h3>
        <span class="flex-1 hidden sm:block h-px bg-border"></span>
        <p class="text-sm text-muted-foreground italic hidden sm:block shrink-0">"Evolving life, engineering futures."</p>
      </div>

      <div class="house-row flex items-center gap-5 md:gap-8 px-6 md:px-16 lg:px-24 py-5 md:py-6 hover:bg-house-hardware/[0.04] cursor-default" style="--pad: 1.5rem">
        <svg class="w-[18px] h-[18px] text-house-hardware shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v10.5a2.25 2.25 0 002.25 2.25zm.75-12h9v9h-9v-9z" />
        </svg>
        <h3 class="text-lg font-bold text-house-hardware">Hardware</h3>
        <span class="flex-1 hidden sm:block h-px bg-border"></span>
        <p class="text-sm text-muted-foreground italic hidden sm:block shrink-0">"Atoms to products."</p>
      </div>
    </div>
  </section>

  <!-- ═══ TARDI ════════════════════════════════════════════════── -->
  <section class="px-6 md:px-16 lg:px-24 py-28 md:py-36 relative overflow-hidden">
    <!-- Subtle purple glow behind Tardi — the mascot radiates brand energy -->
    <div class="absolute left-[10%] top-1/2 -translate-y-1/2 w-[300px] h-[300px] rounded-full pointer-events-none" style="background: radial-gradient(circle, oklch(0.25 0.10 305 / 30%), transparent 70%);"></div>

    <div class="on-scroll relative z-10 flex flex-col md:flex-row items-start gap-16 md:gap-24 max-w-4xl">
      <!-- Tardi image -->
      <div class="w-36 h-36 md:w-48 md:h-48 rounded-2xl bg-accent/50 flex items-center justify-center shrink-0 overflow-hidden">
        <img
          src="/tardi.png"
          alt="Tardi the tardigrade — 404's mascot"
          class="w-28 md:w-40 h-auto object-contain"
        />
      </div>

      <div class="flex-1">
        <p class="label mb-5">Mascot</p>
        <h3 class="text-[clamp(1.5rem,3vw,2.5rem)] font-bold leading-tight mb-3">Tardi</h3>
        <p class="text-sm text-primary font-medium mb-6">The tardigrade. Most resilient creature on Earth.</p>
        <p class="text-[0.9375rem] text-muted-foreground leading-[1.75] max-w-lg">
          Survives vacuum, radiation, and temperatures from near absolute zero
          to boiling. Endures pressures six times the deepest ocean trenches.
          Can desiccate completely and revive decades later. Like our startups —
          built to endure conditions nothing else can.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ COMPONENTS ═══════════════════════════════════════════── -->
  <section class="px-6 md:px-16 lg:px-24 py-20 md:py-28 border-t border-border">
    <p class="on-scroll label mb-14">Components</p>

    <div class="space-y-14 max-w-xl">
      <div class="on-scroll">
        <p class="text-[0.6875rem] text-muted-foreground/50 uppercase tracking-wider mb-5">Buttons</p>
        <div class="flex flex-wrap gap-3">
          <Button client:load size="lg">Primary</Button>
          <Button client:load variant="outline" size="lg">Outline</Button>
          <Button client:load variant="secondary" size="lg">Secondary</Button>
          <Button client:load variant="ghost" size="lg">Ghost</Button>
        </div>
      </div>

      <div class="on-scroll" style="--d: 80ms">
        <p class="text-[0.6875rem] text-muted-foreground/50 uppercase tracking-wider mb-5">Form</p>
        <div class="flex gap-2">
          <input
            type="email"
            placeholder="founder@deeptech.com"
            class="flex-1 h-10 px-3 rounded-lg border border-input bg-card text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring"
          />
          <Button client:load>Subscribe</Button>
        </div>
      </div>

      <div class="on-scroll" style="--d: 160ms">
        <p class="text-[0.6875rem] text-muted-foreground/50 uppercase tracking-wider mb-5">Banner</p>
        <div class="rounded-lg border border-primary/20 bg-primary/[0.04] p-5 flex items-start gap-3">
          <div class="w-8 h-8 rounded-md bg-primary/15 flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-foreground">Cohort II is open</p>
            <p class="text-sm text-muted-foreground mt-1">18 teams. 12 weeks. Applications close March 30.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FOOTER ═══════════════════════════════════════════════── -->
  <footer class="px-6 md:px-16 lg:px-24 py-14 border-t border-border">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div class="flex items-baseline gap-2.5">
        <span class="text-2xl font-black text-primary tracking-[-0.02em]">404</span>
        <span class="text-sm text-muted-foreground/60 tracking-wider">Tech Found</span>
      </div>
      <p class="text-[0.6875rem] text-muted-foreground/40">Brand proposal · Not a production page</p>
    </div>
  </footer>

  <!-- Scroll reveal -->
  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("revealed");
            observer.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.08, rootMargin: "0px 0px -30px 0px" }
    );
    document.querySelectorAll(".on-scroll").forEach((el) => observer.observe(el));
  </script>
</body>
</html>
