---
import "@/styles/global.css"
import { Button } from "@/components/ui/button"
---

<html lang="en" data-theme="foundry">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Foundry Motion & Components — 404 Tech Found</title>
  <style>
    /* ── Entrance choreography ──────────────────────────────── */
    @keyframes emerge {
      from { opacity: 0; transform: translateY(24px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes expand-right {
      from { transform: scaleX(0); }
      to { transform: scaleX(1); }
    }
    @keyframes drift {
      0%, 100% { transform: translateY(0) rotate(0deg); }
      40% { transform: translateY(-8px) rotate(0.3deg); }
      70% { transform: translateY(4px) rotate(-0.15deg); }
    }

    .emerge {
      opacity: 0;
      animation: emerge 700ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
      animation-delay: var(--d, 0ms);
    }
    .on-scroll {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 600ms cubic-bezier(0.16, 1, 0.3, 1),
                  transform 600ms cubic-bezier(0.16, 1, 0.3, 1);
      transition-delay: var(--d, 0ms);
    }
    .on-scroll.revealed {
      opacity: 1;
      transform: translateY(0);
    }

    /* ── Atmospheric layers ─────────────────────────────────── */
    .atmosphere {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: -1;
      background:
        radial-gradient(ellipse 80% 45% at 20% 110%, oklch(0.14 0.08 305 / 35%), transparent 65%),
        radial-gradient(ellipse 40% 35% at 85% 10%, oklch(0.12 0.06 310 / 20%), transparent 55%);
    }

    .grain {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 9998;
      opacity: 0.025;
      mix-blend-mode: overlay;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      background-size: 256px 256px;
    }

    /* ── Section label ──────────────────────────────────────── */
    .label {
      font-family: var(--font-body);
      font-size: 0.6875rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: oklch(0.55 0.22 305 / 65%);
    }

    /* ── Color band / house row interaction ─────────────────── */
    .color-band {
      transition: padding-left 250ms cubic-bezier(0.25, 1, 0.5, 1);
    }
    .color-band:hover {
      padding-left: calc(var(--pad) + 12px);
    }
    .house-row {
      transition: background-color 200ms cubic-bezier(0.25, 1, 0.5, 1),
                  padding-left 200ms cubic-bezier(0.25, 1, 0.5, 1);
    }
    .house-row:hover {
      padding-left: calc(var(--pad) + 6px);
    }

    /* ── Manifesto lines ────────────────────────────────────── */
    .manifesto-line {
      font-family: var(--font-display);
      font-size: clamp(1.6rem, 4.5vw, 3.2rem);
      font-weight: 700;
      line-height: 1.1;
      text-transform: uppercase;
      letter-spacing: 0;
      color: oklch(0.92 0.008 55 / 85%);
      transition: text-shadow 300ms cubic-bezier(0.25, 1, 0.5, 1);
    }
    .manifesto-line:hover {
      text-shadow: 0 0 30px oklch(0.44 0.24 305 / 25%), 0 0 60px oklch(0.44 0.24 305 / 10%);
    }

    /* ── Watermark ──────────────────────────────────────────── */
    .watermark {
      position: absolute;
      font-family: var(--font-display);
      font-size: clamp(15rem, 40vw, 35rem);
      font-weight: 900;
      line-height: 0.8;
      text-transform: uppercase;
      color: oklch(0.44 0.24 305 / 3%);
      pointer-events: none;
      user-select: none;
    }

    /* ── Section divider ────────────────────────────────────── */
    .divider-gradient {
      height: 2px;
      background: linear-gradient(to right, oklch(0.44 0.24 305 / 60%), oklch(0.72 0.18 55 / 60%), transparent);
    }

    /* ── Spec rows ──────────────────────────────────────────── */
    .spec-row {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      padding: 0.75rem 0;
      border-bottom: 1px solid oklch(1 0.008 310 / 5%);
    }
    .spec-label {
      font-family: var(--font-body);
      font-size: 0.75rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: oklch(0.52 0.018 315);
    }
    .spec-value {
      font-family: var(--font-code);
      font-size: 0.75rem;
      color: oklch(0.92 0.008 55 / 60%);
    }

    /* ── Section number — giant background glyph ────────────── */
    .section-number {
      font-family: var(--font-display);
      font-size: clamp(6rem, 15vw, 10rem);
      font-weight: 900;
      line-height: 0.8;
      color: oklch(0.44 0.24 305 / 5%);
      position: absolute;
      right: -2%;
      top: -10%;
      pointer-events: none;
      user-select: none;
    }

    /* ── Easing demos — animated boxes that loop ────────────── */
    @keyframes ease-demo {
      0% { transform: translateX(0); }
      50% { transform: translateX(calc(100% - 2.5rem)); }
      100% { transform: translateX(0); }
    }
    .ease-box {
      width: 2.5rem;
      height: 2.5rem;
      background: oklch(0.44 0.24 305);
      animation-duration: 2.5s;
      animation-iteration-count: infinite;
      animation-name: ease-demo;
    }

    /* ── Duration demo — fade in/out at different speeds ───── */
    @keyframes duration-demo {
      0%, 100% { opacity: 0.15; }
      50% { opacity: 1; }
    }
    .duration-box {
      width: 100%;
      height: 2.5rem;
      background: oklch(0.44 0.24 305 / 30%);
      animation-name: duration-demo;
      animation-iteration-count: infinite;
    }

    /* ── Hover state demos ──────────────────────────────────── */
    .hover-demo {
      transition-property: background-color, color, border-color, box-shadow, transform;
      transition-timing-function: cubic-bezier(0.25, 1, 0.5, 1);
    }

    /* ── Reduced motion ─────────────────────────────────────── */
    @media (prefers-reduced-motion: reduce) {
      .emerge { animation: none; opacity: 1; transform: none; }
      .on-scroll { transition: none; opacity: 1; transform: none; }
      .ease-box { animation: none; transform: none; }
      .duration-box { animation: none; opacity: 0.5; }
      .manifesto-line { transition: none; }
    }
  </style>
</head>

<body class="bg-background text-foreground overflow-x-hidden">
  <div class="atmosphere"></div>
  <div class="grain"></div>

  <!-- Back links -->
  <nav class="fixed top-5 left-6 z-50 flex items-center gap-4">
    <a
      href="/"
      style="font-family: var(--font-body)"
      class="text-[0.625rem] uppercase tracking-[0.2em] text-muted-foreground/80 hover:text-secondary transition-colors duration-200"
    >
      All proposals
    </a>
    <span class="text-muted-foreground/30 text-[0.5rem]">/</span>
    <a
      href="/foundry"
      style="font-family: var(--font-body)"
      class="text-[0.625rem] uppercase tracking-[0.2em] text-muted-foreground/80 hover:text-secondary transition-colors duration-200"
    >
      Foundry Showcase
    </a>
  </nav>

  <!-- ═══ HEADER ═══════════════════════════════════════════════════ -->
  <header class="min-h-[60vh] relative flex items-end px-6 md:px-12 lg:px-20 pb-20 md:pb-28 pt-24">
    <div class="relative z-10 max-w-4xl">
      <p class="label mb-6 emerge" style="--d: 200ms">Foundry Design System · Part II</p>

      <h1 class="emerge" style="--d: 400ms">
        <span
          class="block text-[clamp(3rem,10vw,7rem)] font-black leading-[0.85] tracking-[-0.02em] uppercase"
          style="font-family: var(--font-display)"
        >
          Motion &<br />Components
        </span>
      </h1>

      <p
        class="emerge text-[clamp(0.95rem,1.5vw,1.1rem)] text-muted-foreground max-w-md mt-10 leading-[1.75]"
        style="--d: 700ms"
      >
        How the Foundry moves, responds, and assembles.<br />
        Every easing curve, every state change, every surface.
      </p>
    </div>

    <span class="watermark -right-[5%] bottom-[-15%]">II</span>
  </header>

  <div class="divider-gradient mx-6 md:mx-12 lg:mx-20"></div>


  <!-- ═══ SECTION 5: MOTION LANGUAGE ════════════════════════════════ -->
  <section class="relative px-6 md:px-12 lg:px-20 pt-28 md:pt-40 pb-20 md:pb-28 overflow-hidden">
    <span class="section-number">05</span>

    <div class="relative z-10">
      <p class="on-scroll label mb-4">Section 05</p>
      <h2 class="on-scroll text-[clamp(2rem,5vw,4rem)] font-black leading-[0.9] uppercase mb-6" style="font-family: var(--font-display)">
        Motion Language
      </h2>
      <p class="on-scroll text-sm text-muted-foreground max-w-lg mb-20" style="--d: 80ms">
        Nothing in the Foundry bounces. Nothing overshoots. Movement is deliberate —
        like molten metal finding its mold. Sharp entrance, controlled deceleration, stillness.
      </p>

      <!-- ── 5a. Easing Curves ──────────────────────────────────── -->
      <div class="on-scroll mb-20" style="--d: 120ms">
        <p class="text-[0.6875rem] text-muted-foreground/70 uppercase tracking-wider mb-10">5a · Easing Curves</p>

        <div class="space-y-10">
          <!-- Primary easing -->
          <div class="border-2 border-border bg-card p-6">
            <div class="flex flex-col md:flex-row md:items-start gap-6">
              <div class="flex-1 min-w-0">
                <h4 class="text-sm font-semibold uppercase tracking-wide mb-2" style="color: oklch(0.72 0.18 55)">Primary</h4>
                <div class="spec-row">
                  <span class="spec-label">CSS</span>
                  <span class="spec-value">cubic-bezier(0.16, 1, 0.3, 1)</span>
                </div>
                <div class="spec-row">
                  <span class="spec-label">Character</span>
                  <span class="spec-value">Sharp in, decelerate out</span>
                </div>
                <div class="spec-row" style="border-bottom: none">
                  <span class="spec-label">Usage</span>
                  <span class="spec-value">Entrances and reveals</span>
                </div>
              </div>
              <div class="w-full md:w-64 h-14 bg-background border-2 border-border overflow-hidden flex items-center px-2">
                <div class="ease-box" style="animation-timing-function: cubic-bezier(0.16, 1, 0.3, 1);"></div>
              </div>
            </div>
          </div>

          <!-- Secondary easing -->
          <div class="border-2 border-border bg-card p-6">
            <div class="flex flex-col md:flex-row md:items-start gap-6">
              <div class="flex-1 min-w-0">
                <h4 class="text-sm font-semibold uppercase tracking-wide mb-2" style="color: oklch(0.72 0.18 55)">Secondary</h4>
                <div class="spec-row">
                  <span class="spec-label">CSS</span>
                  <span class="spec-value">cubic-bezier(0.25, 1, 0.5, 1)</span>
                </div>
                <div class="spec-row">
                  <span class="spec-label">Character</span>
                  <span class="spec-value">Gentler deceleration</span>
                </div>
                <div class="spec-row" style="border-bottom: none">
                  <span class="spec-label">Usage</span>
                  <span class="spec-value">Hover states, micro-interactions</span>
                </div>
              </div>
              <div class="w-full md:w-64 h-14 bg-background border-2 border-border overflow-hidden flex items-center px-2">
                <div class="ease-box" style="animation-timing-function: cubic-bezier(0.25, 1, 0.5, 1);"></div>
              </div>
            </div>
          </div>

          <!-- Symmetric easing -->
          <div class="border-2 border-border bg-card p-6">
            <div class="flex flex-col md:flex-row md:items-start gap-6">
              <div class="flex-1 min-w-0">
                <h4 class="text-sm font-semibold uppercase tracking-wide mb-2" style="color: oklch(0.72 0.18 55)">Symmetric</h4>
                <div class="spec-row">
                  <span class="spec-label">CSS</span>
                  <span class="spec-value">cubic-bezier(0.45, 0, 0.55, 1)</span>
                </div>
                <div class="spec-row">
                  <span class="spec-label">Character</span>
                  <span class="spec-value">Even motion, no bias</span>
                </div>
                <div class="spec-row" style="border-bottom: none">
                  <span class="spec-label">Usage</span>
                  <span class="spec-value">Ambient, continuous animation</span>
                </div>
              </div>
              <div class="w-full md:w-64 h-14 bg-background border-2 border-border overflow-hidden flex items-center px-2">
                <div class="ease-box" style="animation-timing-function: cubic-bezier(0.45, 0, 0.55, 1);"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ── 5b. Duration Scale ─────────────────────────────────── -->
      <div class="on-scroll mb-20" style="--d: 160ms">
        <p class="text-[0.6875rem] text-muted-foreground/70 uppercase tracking-wider mb-10">5b · Duration Scale</p>

        <div class="space-y-4 max-w-3xl">
          <!-- Instant -->
          <div class="flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-5">
            <div class="flex items-baseline gap-3 sm:w-48 shrink-0">
              <span class="text-xs font-semibold uppercase tracking-wide" style="color: oklch(0.72 0.18 55)">Instant</span>
              <span class="text-[0.6875rem] font-mono text-muted-foreground">100ms</span>
            </div>
            <div class="flex-1">
              <div class="duration-box" style="animation-duration: 200ms;"></div>
            </div>
            <span class="text-[0.6875rem] text-muted-foreground/60 sm:w-48 shrink-0 sm:text-right">Color transitions, opacity micro</span>
          </div>

          <!-- Quick -->
          <div class="flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-5">
            <div class="flex items-baseline gap-3 sm:w-48 shrink-0">
              <span class="text-xs font-semibold uppercase tracking-wide" style="color: oklch(0.72 0.18 55)">Quick</span>
              <span class="text-[0.6875rem] font-mono text-muted-foreground">200ms</span>
            </div>
            <div class="flex-1">
              <div class="duration-box" style="animation-duration: 400ms;"></div>
            </div>
            <span class="text-[0.6875rem] text-muted-foreground/60 sm:w-48 shrink-0 sm:text-right">Hover states, button interactions</span>
          </div>

          <!-- Standard -->
          <div class="flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-5">
            <div class="flex items-baseline gap-3 sm:w-48 shrink-0">
              <span class="text-xs font-semibold uppercase tracking-wide" style="color: oklch(0.72 0.18 55)">Standard</span>
              <span class="text-[0.6875rem] font-mono text-muted-foreground">350ms</span>
            </div>
            <div class="flex-1">
              <div class="duration-box" style="animation-duration: 700ms;"></div>
            </div>
            <span class="text-[0.6875rem] text-muted-foreground/60 sm:w-48 shrink-0 sm:text-right">Panel transitions, small reveals</span>
          </div>

          <!-- Expressive -->
          <div class="flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-5">
            <div class="flex items-baseline gap-3 sm:w-48 shrink-0">
              <span class="text-xs font-semibold uppercase tracking-wide" style="color: oklch(0.72 0.18 55)">Expressive</span>
              <span class="text-[0.6875rem] font-mono text-muted-foreground">600ms</span>
            </div>
            <div class="flex-1">
              <div class="duration-box" style="animation-duration: 1200ms;"></div>
            </div>
            <span class="text-[0.6875rem] text-muted-foreground/60 sm:w-48 shrink-0 sm:text-right">Entrance animations, scroll reveals</span>
          </div>

          <!-- Dramatic -->
          <div class="flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-5">
            <div class="flex items-baseline gap-3 sm:w-48 shrink-0">
              <span class="text-xs font-semibold uppercase tracking-wide" style="color: oklch(0.72 0.18 55)">Dramatic</span>
              <span class="text-[0.6875rem] font-mono text-muted-foreground">900ms</span>
            </div>
            <div class="flex-1">
              <div class="duration-box" style="animation-duration: 1800ms;"></div>
            </div>
            <span class="text-[0.6875rem] text-muted-foreground/60 sm:w-48 shrink-0 sm:text-right">Hero entrance, hero rule</span>
          </div>

          <!-- Ambient -->
          <div class="flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-5">
            <div class="flex items-baseline gap-3 sm:w-48 shrink-0">
              <span class="text-xs font-semibold uppercase tracking-wide" style="color: oklch(0.72 0.18 55)">Ambient</span>
              <span class="text-[0.6875rem] font-mono text-muted-foreground">14s</span>
            </div>
            <div class="flex-1">
              <div class="duration-box" style="animation-duration: 28s;"></div>
            </div>
            <span class="text-[0.6875rem] text-muted-foreground/60 sm:w-48 shrink-0 sm:text-right">Tardi drift, atmospheric loops</span>
          </div>
        </div>
      </div>

      <!-- ── 5c. Animation Principles ───────────────────────────── -->
      <div class="on-scroll" style="--d: 200ms">
        <p class="text-[0.6875rem] text-muted-foreground/70 uppercase tracking-wider mb-10">5c · Animation Principles</p>

        <div class="max-w-2xl border-t-2 border-border">
          <div class="border-b-2 border-border py-6 flex gap-6">
            <span class="text-[0.6875rem] font-mono text-primary/60 shrink-0 pt-0.5 w-6 text-right">01</span>
            <div>
              <p class="text-sm font-semibold text-foreground/90 mb-1">Elements animate IN but don't animate OUT</p>
              <p class="text-[0.8125rem] text-muted-foreground leading-relaxed">Entrance only. No exit animations for scroll content. Once revealed, the element stays.</p>
            </div>
          </div>
          <div class="border-b-2 border-border py-6 flex gap-6">
            <span class="text-[0.6875rem] font-mono text-primary/60 shrink-0 pt-0.5 w-6 text-right">02</span>
            <div>
              <p class="text-sm font-semibold text-foreground/90 mb-1">Stagger siblings by 80ms</p>
              <p class="text-[0.8125rem] text-muted-foreground leading-relaxed">Via <code class="text-[0.75rem] font-mono text-primary/80 bg-primary/5 px-1.5 py-0.5">--d</code> CSS custom property. Creates a cascading reveal without orchestration complexity.</p>
            </div>
          </div>
          <div class="border-b-2 border-border py-6 flex gap-6">
            <span class="text-[0.6875rem] font-mono text-primary/60 shrink-0 pt-0.5 w-6 text-right">03</span>
            <div>
              <p class="text-sm font-semibold text-foreground/90 mb-1">Only animate: opacity, transform, color, shadows</p>
              <p class="text-[0.8125rem] text-muted-foreground leading-relaxed">Never animate layout properties. No width, height, padding, or margin transitions. The compositor does the work.</p>
            </div>
          </div>
          <div class="py-6 flex gap-6">
            <span class="text-[0.6875rem] font-mono text-primary/60 shrink-0 pt-0.5 w-6 text-right">04</span>
            <div>
              <p class="text-sm font-semibold text-foreground/90 mb-1">Reduced motion: instant, no transform</p>
              <p class="text-[0.8125rem] text-muted-foreground leading-relaxed">Respect <code class="text-[0.75rem] font-mono text-primary/80 bg-primary/5 px-1.5 py-0.5">prefers-reduced-motion</code>. Content appears immediately. No transforms. Opacity jumps to 1.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider-gradient mx-6 md:mx-12 lg:mx-20"></div>


  <!-- ═══ SECTION 6: INTERACTION STATES ═════════════════════════════ -->
  <section class="relative px-6 md:px-12 lg:px-20 pt-28 md:pt-40 pb-20 md:pb-28 overflow-hidden">
    <span class="section-number">06</span>

    <div class="relative z-10">
      <p class="on-scroll label mb-4">Section 06</p>
      <h2 class="on-scroll text-[clamp(2rem,5vw,4rem)] font-black leading-[0.9] uppercase mb-6" style="font-family: var(--font-display)">
        Interaction States
      </h2>
      <p class="on-scroll text-sm text-muted-foreground max-w-lg mb-20" style="--d: 80ms">
        Every touchable surface declares its state. No ambiguity.
        The user always knows what's live, what's focused, what's done.
      </p>

      <!-- ── 6a. Button States ──────────────────────────────────── -->
      <div class="on-scroll mb-20" style="--d: 120ms">
        <p class="text-[0.6875rem] text-muted-foreground/70 uppercase tracking-wider mb-10">6a · Button States</p>

        <!-- Primary buttons -->
        <div class="mb-12">
          <p class="text-xs font-semibold uppercase tracking-wide text-foreground/60 mb-5">Primary (Purple)</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
            <!-- Default -->
            <div class="border-2 border-border bg-card p-5 flex flex-col items-center gap-3">
              <Button client:load size="default" className="text-sm tracking-wide uppercase font-semibold">
                Default
              </Button>
              <span class="text-[0.6rem] font-mono text-muted-foreground/60 text-center">bg-primary<br />text-primary-foreground</span>
            </div>
            <!-- Hover -->
            <div class="border-2 border-border bg-card p-5 flex flex-col items-center gap-3">
              <button
                class="group/button inline-flex shrink-0 items-center justify-center border border-transparent text-sm font-semibold tracking-wide uppercase whitespace-nowrap select-none h-8 gap-1.5 px-2.5"
                style="background: oklch(0.44 0.24 305 / 90%); color: oklch(0.95 0.008 310);"
              >
                Hover
              </button>
              <span class="text-[0.6rem] font-mono text-muted-foreground/60 text-center">bg-primary/90</span>
            </div>
            <!-- Focus -->
            <div class="border-2 border-border bg-card p-5 flex flex-col items-center gap-3">
              <button
                class="group/button inline-flex shrink-0 items-center justify-center border border-transparent text-sm font-semibold tracking-wide uppercase whitespace-nowrap select-none h-8 gap-1.5 px-2.5 ring-2 ring-offset-2"
                style="background: oklch(0.44 0.24 305); color: oklch(0.95 0.008 310); --tw-ring-color: oklch(0.55 0.22 305); --tw-ring-offset-color: oklch(0.07 0.015 320);"
              >
                Focus
              </button>
              <span class="text-[0.6rem] font-mono text-muted-foreground/60 text-center">ring-2 ring-ring<br />ring-offset-2</span>
            </div>
            <!-- Active -->
            <div class="border-2 border-border bg-card p-5 flex flex-col items-center gap-3">
              <button
